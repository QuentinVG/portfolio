---
import { asset as buildAsset } from "../lib/site";

type NavItem = {
  href: string;
  label: string;
  cta?: boolean;
};

type Props = {
  subtitle: string;
  navItems: NavItem[];
  brandHref?: string;
};

const { subtitle, navItems, brandHref = buildAsset(import.meta.env.BASE_URL, "") } = Astro.props as Props;
---

<header class="site-header">
  <a class="brand" href={brandHref} aria-label="Retour accueil">
    <span>Quentin Vial-Gouteyron</span>
    <small>{subtitle}</small>
  </a>
  <nav aria-label="Navigation principale">
    {navItems.map((item) => <a class:list={{ "nav-cta": item.cta }} href={item.href}>{item.label}</a>)}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(20px, 5vw, 72px);
    border-bottom: 1px solid rgba(216, 208, 196, 0.78);
    background: rgba(246, 243, 237, 0.94);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: grid;
    gap: 2px;
    color: inherit;
    font-weight: 900;
    text-decoration: none;
  }

  .brand small {
    color: var(--muted);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(12px, 2.3vw, 28px);
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  nav a {
    color: inherit;
    text-decoration: none;
  }

  .nav-cta {
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    padding: 8px 12px;
    color: var(--accent-dark);
    background: var(--soft-green);
  }

  a:focus-visible {
    outline: 3px solid rgba(50, 108, 96, 0.28);
    outline-offset: 3px;
  }

  @media (max-width: 700px) {
    .site-header {
      position: static;
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
