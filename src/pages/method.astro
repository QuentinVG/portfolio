---
const contactEmail = "vialgouteyron@gmail.com";
const repoUrl = "https://github.com/QuentinVG/portfolio";
const asset = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;

const briefHref = asset("brief");
const steps = [
  {
    title: "Comprendre le besoin réel",
    text: "Identifier l'objectif, les utilisateurs, les données manipulées, les contraintes et ce qui bloque aujourd'hui.",
    output: "Une synthèse courte du contexte et du résultat attendu.",
  },
  {
    title: "Réduire le périmètre",
    text: "Isoler une V1 utile, sortir les options de confort et éviter les fonctionnalités qui rendent le projet trop large.",
    output: "Un découpage V1 / plus tard / hors périmètre.",
  },
  {
    title: "Estimer avec prudence",
    text: "Chiffrer par lots, expliciter les hypothèses et signaler les dépendances qui peuvent changer l'effort.",
    output: "Une estimation lisible, avec risques et questions ouvertes.",
  },
  {
    title: "Construire proprement",
    text: "Livrer une solution simple, compréhensible et maintenable, avec les tests et vérifications adaptés au risque.",
    output: "Une première version utilisable, pas une promesse de plateforme complète.",
  },
  {
    title: "Livrer et décider la suite",
    text: "Regrouper les retours, corriger ce qui bloque vraiment, puis décider si une V2 mérite d'être développée.",
    output: "Un bilan court : livré, reste à faire, arbitrages possibles.",
  },
];

const principles = [
  "Un besoin flou ne doit pas entrer directement en développement.",
  "Une V1 courte réduit les risques mieux qu'un gros devis global.",
  "Les contraintes de temps doivent être visibles dès le départ.",
  "Le code doit rester proportionné à l'enjeu du projet.",
  "L'IA peut accélérer l'analyse, mais elle ne remplace pas la responsabilité technique.",
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="icon" href={asset("favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Méthode de cadrage de Quentin Vial-Gouteyron pour petits projets web, outils métier et automatisations simples."
    />
    <title>Méthode - Quentin Vial-Gouteyron</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={asset("")}>
        <span>Quentin Vial-Gouteyron</span>
        <small>Méthode de cadrage</small>
      </a>
      <nav>
        <a href={asset("")}>Portfolio</a>
        <a class="nav-cta" href={briefHref}>Préparer un brief</a>
      </nav>
    </header>

    <main>
      <section class="hero section-pad">
        <div>
          <p class="eyebrow">Méthode</p>
          <h1>Clarifier avant de coder.</h1>
          <p class="lead">
            Mon approche est volontairement simple : comprendre, réduire, estimer, construire, puis décider la suite.
            C'est ce qui permet de garder un petit projet utile sans le transformer en chantier permanent.
          </p>
          <div class="actions">
            <a class="button primary" href={briefHref}>Tester l'assistant</a>
            <a class="button secondary" href={repoUrl} rel="noreferrer" target="_blank">Voir le dépôt</a>
          </div>
        </div>
        <aside class="side-note">
          <strong>Cadre assumé</strong>
          <p>
            Je privilégie les projets courts, les retours regroupés, les délais réalistes et les périmètres écrits.
            C'est moins spectaculaire qu'une grosse promesse, mais plus fiable.
          </p>
        </aside>
      </section>

      <section class="section-pad">
        <div class="section-heading">
          <p class="eyebrow">Déroulé</p>
          <h2>Les étapes qui évitent la dérive.</h2>
        </div>
        <div class="step-list">
          {steps.map((step, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <div>
                <h3>{step.title}</h3>
                <p>{step.text}</p>
                <strong>Livrable : {step.output}</strong>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad principles-section">
        <div class="section-heading">
          <p class="eyebrow">Principes</p>
          <h2>Ce que la méthode protège.</h2>
        </div>
        <div class="principle-grid">
          {principles.map((item) => (
            <article>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="contact-section">
        <div>
          <p class="eyebrow">Point de départ</p>
          <h2>Le brief reste le meilleur premier filtre.</h2>
          <p>
            Un bon brief ne remplace pas un échange, mais il permet déjà de voir si le projet est raisonnable,
            trop flou ou à découper.
          </p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={briefHref}>Préparer un brief</a>
          <a class="button ghost" href={`mailto:${contactEmail}`}>Envoyer un email</a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f7f6f2;
    --bg-soft: #eef1ee;
    --surface: #ffffff;
    --ink: #202124;
    --muted: #62645f;
    --line: #d6ddd6;
    --accent: #326c60;
    --accent-dark: #1f493f;
    --cool: #415b66;
    --soft-green: #edf5f1;
    --shadow: 0 20px 54px rgba(32, 33, 36, 0.1);
    --shadow-strong: 0 28px 80px rgba(31, 73, 63, 0.16);
    --radius: 8px;
    --page: 1160px;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  p,
  h1,
  h2,
  h3 {
    overflow-wrap: anywhere;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(20px, 5vw, 72px);
    border-bottom: 1px solid rgba(216, 208, 196, 0.78);
    background: rgba(246, 243, 237, 0.94);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: grid;
    gap: 2px;
    font-weight: 900;
  }

  .brand small,
  p {
    color: var(--muted);
  }

  nav,
  .actions,
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  nav {
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .nav-cta {
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--accent-dark);
    background: var(--soft-green);
  }

  .section-pad {
    padding: clamp(56px, 8vw, 104px) max(clamp(20px, 5vw, 72px), calc((100vw - var(--page)) / 2));
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.42fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
  }

  h1 {
    max-width: 900px;
    font-size: clamp(2.45rem, 5vw, 5rem);
    line-height: 1;
  }

  h2 {
    font-size: clamp(1.9rem, 3.2vw, 3.1rem);
    line-height: 1.06;
  }

  h3 {
    font-size: 1.16rem;
  }

  .lead {
    max-width: 780px;
    margin: 26px 0 0;
    font-size: clamp(1.08rem, 1.7vw, 1.28rem);
    line-height: 1.62;
  }

  .actions {
    margin-top: 32px;
  }

  .button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 13px 18px;
    font-weight: 900;
    transition:
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(32, 33, 36, 0.08);
  }

  .button:focus-visible,
  a:focus-visible {
    outline: 3px solid rgba(50, 108, 96, 0.28);
    outline-offset: 3px;
  }

  .button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .button.secondary,
  .button.ghost {
    background: transparent;
  }

  .side-note,
  .step-list article,
  .principle-grid article {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .side-note {
    padding: 24px;
    box-shadow: var(--shadow-strong);
    background:
      linear-gradient(135deg, rgba(237, 245, 241, 0.88), rgba(255, 255, 255, 0) 42%),
      var(--surface);
  }

  .side-note p,
  .step-list p,
  .principle-grid p,
  .contact-section p {
    line-height: 1.62;
  }

  .section-heading {
    max-width: 820px;
    margin-bottom: 34px;
  }

  .step-list {
    display: grid;
    gap: 14px;
    position: relative;
  }

  .step-list article {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr);
    gap: 20px;
    padding: 24px;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .step-list article:hover,
  .principle-grid article:hover {
    border-color: rgba(50, 108, 96, 0.38);
    box-shadow: 0 14px 34px rgba(32, 33, 36, 0.08);
    transform: translateY(-2px);
  }

  .step-list span {
    color: rgba(160, 98, 69, 0.42);
    font-size: 2.4rem;
    font-weight: 950;
    line-height: 1;
  }

  .step-list p {
    margin: 12px 0;
  }

  .principles-section {
    background: var(--surface);
  }

  .principle-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .principle-grid article {
    padding: 22px;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .principle-grid p {
    margin: 0;
    font-weight: 850;
  }

  .contact-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: clamp(24px, 5vw, 60px);
    align-items: center;
    margin: 0 max(clamp(20px, 5vw, 72px), calc((100vw - var(--page)) / 2)) clamp(32px, 5vw, 60px);
    padding: clamp(32px, 6vw, 64px);
    border-radius: var(--radius);
    background:
      linear-gradient(135deg, rgba(63, 111, 98, 0.34), rgba(32, 33, 36, 0) 44%),
      var(--ink);
    color: #fff;
  }

  .contact-section .eyebrow {
    color: #b9d7c6;
  }

  .contact-section p {
    color: rgba(255, 255, 255, 0.76);
  }

  .contact-actions {
    align-items: stretch;
    flex-direction: column;
    justify-content: center;
    margin-top: 0;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius);
    padding: 18px;
    background: rgba(255, 255, 255, 0.06);
  }

  .contact-actions .button {
    width: 100%;
    color: #fff;
  }

  @media (max-width: 920px) {
    .hero,
    .contact-section {
      grid-template-columns: 1fr;
    }

    .principle-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .site-header {
      position: static;
      align-items: flex-start;
      flex-direction: column;
    }

    h1 {
      font-size: clamp(2.25rem, 10.8vw, 3rem);
      line-height: 1.02;
    }

    .actions,
    .contact-actions {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
      white-space: normal;
    }

    .step-list article,
    .principle-grid {
      grid-template-columns: 1fr;
    }

    .contact-section {
      margin-right: 20px;
      margin-left: 20px;
    }
  }
</style>
