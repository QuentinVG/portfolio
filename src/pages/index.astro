---
const projects = [
  {
    title: "Restaurant de quartier",
    category: "Site vitrine",
    image: "/projects/restaurant-web.png",
    alt: "Mockup de site restaurant responsive",
    description:
      "Une page claire pour presenter le menu, les horaires, la localisation et convertir les visiteurs mobile en appels ou reservations.",
    points: ["Menu lisible", "Appel rapide", "Carte et horaires"],
  },
  {
    title: "Artisan renovation",
    category: "Demande de devis",
    image: "/projects/artisan-web.png",
    alt: "Mockup de site artisan responsive",
    description:
      "Un site de confiance pour expliquer les prestations, montrer les realisations et recevoir des demandes qualifiees.",
    points: ["Services detailles", "Zone d'intervention", "Formulaire devis"],
  },
  {
    title: "Suivi clients",
    category: "Mini application",
    image: "/projects/dashboard-web.png",
    alt: "Mockup de tableau de bord web",
    description:
      "Un tableau de bord simple pour suivre les prospects, rendez-vous et devis d'une petite activite de service.",
    points: ["Pipeline clients", "Planning", "Indicateurs utiles"],
  },
];

const services = [
  "Site vitrine rapide et responsive",
  "Landing page pour une offre precise",
  "Refonte d'un site vieillissant",
  "Formulaire de contact ou demande de devis",
  "Maintenance et petites evolutions",
];

const process = [
  ["01", "Cadrage", "On clarifie l'objectif, les contenus et ce qui doit convertir."],
  ["02", "Maquette", "Je propose une structure simple avant de developper."],
  ["03", "Mise en ligne", "Le site est livre responsive, rapide et pret a partager."],
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Portfolio de Quentin, creation de sites web clairs et rapides pour independants, commerces et petites structures." />
    <meta name="generator" content={Astro.generator} />
    <title>Quentin - Sites web pour petites entreprises</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Retour accueil">Quentin</a>
      <nav aria-label="Navigation principale">
        <a href="#services">Services</a>
        <a href="#projets">Projets</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">Developpement web freelance</p>
          <h1>Des sites web clairs, rapides et utiles pour petites entreprises.</h1>
          <p class="lead">
            J'aide les independants, commerces et associations a transformer une idee simple en site propre,
            lisible sur mobile et pret a recevoir des contacts.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="#projets">Voir les exemples</a>
            <a class="button secondary" href="mailto:vialgouteyron@gmail.com">Me contacter</a>
          </div>
        </div>
        <aside class="hero-panel" aria-label="Resume de l'offre">
          <div>
            <span class="metric">7-14j</span>
            <span class="label">delai cible pour une premiere version</span>
          </div>
          <div>
            <span class="metric">Mobile</span>
            <span class="label">prioritaire sur chaque projet</span>
          </div>
          <div>
            <span class="metric">Simple</span>
            <span class="label">facile a maintenir et a faire evoluer</span>
          </div>
        </aside>
      </section>

      <section id="services" class="section">
        <div class="section-heading">
          <p class="eyebrow">Services</p>
          <h2>Ce que je peux livrer</h2>
        </div>
        <div class="service-grid">
          {services.map((service) => (
            <article class="service-card">
              <span aria-hidden="true">+</span>
              <h3>{service}</h3>
            </article>
          ))}
        </div>
      </section>

      <section id="projets" class="section projects-section">
        <div class="section-heading">
          <p class="eyebrow">Projets demo</p>
          <h2>Des exemples orientes client</h2>
          <p>
            Ces demos montrent le type de livrable que je peux adapter a un vrai commerce, artisan ou service local.
          </p>
        </div>
        <div class="projects">
          {projects.map((project) => (
            <article class="project-card">
              <img src={project.image} alt={project.alt} loading="lazy" />
              <div class="project-content">
                <p class="category">{project.category}</p>
                <h3>{project.title}</h3>
                <p>{project.description}</p>
                <ul>
                  {project.points.map((point) => <li>{point}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section process-section">
        <div class="section-heading">
          <p class="eyebrow">Methode</p>
          <h2>Un processus court et lisible</h2>
        </div>
        <div class="process-grid">
          {process.map(([number, title, text]) => (
            <article class="process-step">
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>On part d'un besoin concret.</h2>
          <p>
            Envoyez-moi le type de site voulu, vos contenus disponibles et le delai souhaite.
            Je reviens avec une proposition simple.
          </p>
        </div>
        <a class="button primary" href="mailto:vialgouteyron@gmail.com">vialgouteyron@gmail.com</a>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f7f4ef;
    --surface: #ffffff;
    --ink: #1b1b1d;
    --muted: #68635d;
    --line: #ddd7cf;
    --accent: #167c80;
    --accent-dark: #0d5054;
    --warm: #c2603d;
    --shadow: 0 22px 70px rgba(26, 25, 23, 0.12);
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: var(--ink);
    background: var(--bg);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 18px clamp(20px, 5vw, 72px);
    border-bottom: 1px solid rgba(221, 215, 207, 0.72);
    background: rgba(247, 244, 239, 0.9);
    backdrop-filter: blur(14px);
  }

  .brand {
    font-weight: 800;
    font-size: 1.05rem;
  }

  nav {
    display: flex;
    gap: clamp(14px, 3vw, 30px);
    color: var(--muted);
    font-size: 0.95rem;
  }

  nav a:hover {
    color: var(--ink);
  }

  main {
    overflow: hidden;
  }

  .hero {
    min-height: calc(100vh - 73px);
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(28px, 6vw, 90px);
    align-items: center;
    padding: clamp(56px, 8vw, 112px) clamp(20px, 5vw, 72px) clamp(44px, 6vw, 80px);
  }

  .eyebrow,
  .category {
    margin: 0 0 14px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1 {
    max-width: 920px;
    margin: 0;
    font-size: clamp(2.8rem, 7vw, 6.6rem);
    line-height: 0.95;
    letter-spacing: 0;
  }

  h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.8rem);
    line-height: 1;
    letter-spacing: 0;
  }

  h3 {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.25;
  }

  .lead {
    max-width: 720px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: 8px;
    padding: 13px 18px;
    font-weight: 800;
  }

  .button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .button.secondary {
    background: transparent;
  }

  .hero-panel {
    display: grid;
    gap: 18px;
    padding: 28px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .hero-panel div {
    padding-bottom: 18px;
    border-bottom: 1px solid var(--line);
  }

  .hero-panel div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .metric {
    display: block;
    font-size: clamp(2rem, 4vw, 3.6rem);
    font-weight: 900;
    line-height: 1;
  }

  .label {
    display: block;
    margin-top: 8px;
    color: var(--muted);
    line-height: 1.45;
  }

  .section {
    padding: clamp(58px, 8vw, 108px) clamp(20px, 5vw, 72px);
  }

  .section-heading {
    max-width: 760px;
    margin-bottom: 32px;
  }

  .section-heading p:not(.eyebrow) {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .service-grid,
  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .service-card,
  .process-step,
  .project-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
  }

  .service-card {
    display: flex;
    min-height: 116px;
    gap: 18px;
    align-items: flex-start;
    padding: 22px;
  }

  .service-card span {
    display: grid;
    width: 28px;
    height: 28px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 50%;
    background: #efe6dc;
    color: var(--warm);
    font-weight: 900;
  }

  .projects-section {
    background: #ebe8e1;
  }

  .projects {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .project-card {
    overflow: hidden;
    box-shadow: 0 18px 48px rgba(26, 25, 23, 0.08);
  }

  .project-card img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    background: #d8d2ca;
  }

  .project-content {
    padding: 24px;
  }

  .project-content p:not(.category) {
    color: var(--muted);
    line-height: 1.55;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 18px 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 7px 10px;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .process-step {
    padding: 26px;
  }

  .process-step span {
    display: block;
    margin-bottom: 28px;
    color: var(--warm);
    font-size: 2.4rem;
    font-weight: 900;
  }

  .process-step p {
    color: var(--muted);
    line-height: 1.55;
  }

  .contact-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: center;
    margin: 0 clamp(20px, 5vw, 72px) clamp(28px, 5vw, 56px);
    padding: clamp(30px, 6vw, 58px);
    border-radius: 8px;
    background: var(--ink);
    color: #fff;
  }

  .contact-section .eyebrow {
    color: #79d1ce;
  }

  .contact-section p:not(.eyebrow) {
    max-width: 760px;
    color: rgba(255, 255, 255, 0.74);
    line-height: 1.6;
  }

  .contact-section .button {
    white-space: nowrap;
  }

  @media (max-width: 920px) {
    .hero,
    .contact-section {
      grid-template-columns: 1fr;
    }

    .service-grid,
    .projects,
    .process-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .site-header {
      position: static;
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      width: 100%;
      justify-content: space-between;
    }

    .hero {
      min-height: auto;
      padding-top: 44px;
    }

    .service-grid,
    .projects,
    .process-grid {
      grid-template-columns: 1fr;
    }

    .button,
    .contact-section .button {
      width: 100%;
      white-space: normal;
    }
  }
</style>
