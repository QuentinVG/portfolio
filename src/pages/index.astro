---
const contactEmail = "vialgouteyron@gmail.com";
const githubUrl = "https://github.com/QuentinVG";
const linkedinUrl = "https://www.linkedin.com/in/qvg/";
const asset = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;

const briefHref = asset("brief");
const mailSubject = "Demande de cadrage pour un projet web";
const mailBody = `Bonjour Quentin,

Je vous contacte pour un projet web ou outil métier.

Contexte :
Objectif principal :
Utilisateurs concernés :
Données ou outils existants :
Délai souhaité :
Budget approximatif :
Ce qui est déjà prêt :

Merci,`;
const mailHref = `mailto:${contactEmail}?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;

const useCases = [
  {
    title: "Site utile",
    text: "Une présence web claire pour présenter une activité, rassurer et faciliter la prise de contact.",
  },
  {
    title: "Outil métier léger",
    text: "Un formulaire avancé, un tableau de suivi, un mini back-office ou un flux simple pour réduire les tâches répétitives.",
  },
  {
    title: "Cadrage technique",
    text: "Un besoin flou transformé en périmètre, priorités, risques, questions et première estimation réaliste.",
  },
];

const strengths = [
  "Environ 9 ans d'expérience professionnelle en développement web PHP.",
  "Habitude des environnements métier, des personnalisations client et des contraintes de maintenance.",
  "Analyse de specs, chiffrage, conception technique, debug, tests, commits, revues et suivi de tickets.",
  "Approche lead dev : clarifier, prioriser, découper, sécuriser la qualité et rester pragmatique.",
  "Utilisation raisonnée de l'IA en assistant de développement pour accélérer l'analyse et les workflows.",
];

const goodFit = [
  "Besoin utile, court ou découpable.",
  "Référent disponible pour valider les décisions.",
  "Périmètre écrit avant démarrage.",
  "Retours regroupés plutôt que micro-demandes permanentes.",
  "Projet compatible avec une disponibilité soir/week-end.",
];

const badFit = [
  "Urgence permanente ou support quotidien.",
  "Gros e-commerce, marketplace ou SaaS complet.",
  "Projet sans périmètre, sans référent ou sans objectif clair.",
  "Budget très bas avec attentes élevées.",
  "Maintenance ouverte sans cadre.",
];

const examples = [
  {
    title: "Import métier contrôlé",
    problem: "Des données doivent être récupérées depuis un fichier ou un outil existant sans casser le processus.",
    answer: "Contrôles, erreurs lisibles, résumé d'import et garde-fous pour éviter les doubles saisies.",
  },
  {
    title: "Workflow de validation",
    problem: "Une équipe perd du temps parce que les demandes passent par trop de messages et validations informelles.",
    answer: "États clairs, actions autorisées, historique et notifications simples pour rendre le flux lisible.",
  },
  {
    title: "Écran lent ou confus",
    problem: "Un écran métier charge trop de données, mélange les informations et ralentit les décisions.",
    answer: "Tri des priorités, requêtes allégées, filtres utiles et interface plus directe.",
  },
  {
    title: "Mini back-office",
    problem: "Une petite structure suit encore ses demandes dans des fichiers ou emails dispersés.",
    answer: "Un outil simple pour centraliser, filtrer, commenter et suivre l'avancement sans construire une usine.",
  },
];

const process = [
  ["01", "Clarifier", "Comprendre l'objectif, les utilisateurs, les données et ce qui bloque vraiment."],
  ["02", "Cadrer", "Écrire un périmètre court, les hypothèses, les risques et les choix à valider."],
  ["03", "Construire", "Développer une version utile, maintenable, testable et adaptée au budget."],
  ["04", "Livrer", "Regrouper les retours, corriger proprement et documenter le minimum nécessaire."],
];

const caseStudy = {
  title: "Flux de demandes internes trop dispersé",
  context:
    "Une petite équipe suit des demandes dans des emails, fichiers et échanges informels. L'information existe, mais personne ne sait vraiment quel élément fait foi.",
  constraint:
    "Le besoin paraît simple au départ, mais il touche aux statuts, aux validations, aux droits et à l'historique. Sans cadrage, le projet peut vite devenir un mini ERP.",
  decision:
    "Réduire la V1 à un suivi clair : création de demande, statut, commentaire, filtre, historique minimal et export. Le reste passe en options à arbitrer.",
  result:
    "Un périmètre plus court, plus facile à estimer, avec moins de risques de dérive et une première version réellement livrable.",
};
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="icon" href={asset("favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Quentin Vial-Gouteyron, développeur web PHP à Valence, aide les petites structures à cadrer et construire des sites utiles, outils métier légers et automatisations simples."
    />
    <meta name="generator" content={Astro.generator} />
    <title>Quentin Vial-Gouteyron - Développeur PHP, sites utiles et outils métier</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Retour accueil">
        <span>Quentin Vial-Gouteyron</span>
        <small>Développeur PHP à Valence</small>
      </a>
      <nav aria-label="Navigation principale">
        <a href="#approche">Approche</a>
        <a href="#cadre">Cadre</a>
        <a href="#exemples">Exemples</a>
        <a class="nav-cta" href={briefHref}>Préparer un brief</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero section-pad">
        <div class="hero-copy">
          <p class="eyebrow">Valence, Drôme, Ardèche et France à distance</p>
          <h1>Des sites utiles et outils métier simples, cadrés avec une rigueur de lead dev.</h1>
          <p class="lead">
            J'aide les petites structures à transformer un besoin flou en site, mini outil web ou automatisation légère,
            sans complexité inutile ni promesse impossible à tenir.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={briefHref}>Préparer mon brief</a>
            <a class="button secondary" href={mailHref}>Me contacter</a>
          </div>
          <p class="small-note">
            Je privilégie les projets courts, raisonnables et bien cadrés. L'objectif est de livrer quelque chose d'utile,
            maintenable et adapté à votre contexte, pas de construire une usine à gaz.
          </p>
        </div>

        <aside class="proof-panel" aria-label="Résumé du profil">
          <p class="panel-label">Profil</p>
          <h2>Lead developer PHP, environ 9 ans d'expérience.</h2>
          <p>
            Développement PHP, MySQL/MariaDB, JavaScript, HTML/CSS, Git, analyse fonctionnelle, chiffrage,
            debug, corrections, tests, revues et suivi de projets.
          </p>
          <div class="metric-grid">
            <span><strong>9 ans</strong> web métier</span>
            <span><strong>PHP</strong> backend</span>
            <span><strong>Lead</strong> cadrage</span>
            <span><strong>IA</strong> workflows</span>
          </div>
        </aside>
      </section>

      <section id="approche" class="section-pad intro-section">
        <div class="section-heading">
          <p class="eyebrow">Positionnement</p>
          <h2>Pas seulement un site vitrine. Un besoin utile, clarifié et construit proprement.</h2>
          <p>
            Un site simple peut être pertinent. Mais ma vraie valeur est de comprendre le besoin métier, poser les limites,
            repérer les risques et construire une solution sobre qui reste maintenable.
          </p>
        </div>
        <div class="card-grid three">
          {useCases.map((item) => (
            <article class="card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad app-section">
        <div class="app-copy">
          <p class="eyebrow">Démo interactive</p>
          <h2>Essayez l'assistant de cadrage.</h2>
          <p>
            Cette mini app pose les premières questions utiles, estime la complexité, détecte les points flous
            et génère un résumé prêt à envoyer. Elle montre la méthode autant que le code.
          </p>
        </div>
        <div class="app-card">
          <span class="status">Disponible</span>
          <h3>Assistant de cadrage</h3>
          <p>Besoin, complexité, contexte, risques, questions à clarifier et synthèse email.</p>
          <div class="product-preview" aria-label="Aperçu du résultat généré">
            <div>
              <span>Score</span>
              <strong>15/37</strong>
            </div>
            <div>
              <span>Lecture</span>
              <strong>Complexité moyenne</strong>
            </div>
            <ul>
              <li>Délai court à clarifier</li>
              <li>Version minimale à isoler</li>
              <li>Données existantes à valider</li>
            </ul>
          </div>
          <a class="button primary" href={briefHref}>Lancer l'assistant</a>
        </div>
      </section>

      <section class="section-pad strength-section">
        <div class="section-heading narrow">
          <p class="eyebrow">Ce que j'apporte</p>
          <h2>Une approche de lead dev appliquée à des projets raisonnables.</h2>
        </div>
        <div class="strength-list">
          {strengths.map((item) => (
            <article>
              <span aria-hidden="true">OK</span>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="cadre" class="section-pad fit-section">
        <div class="fit-card good">
          <p class="eyebrow">Bon cadre</p>
          <h2>Ce que je recherche.</h2>
          <ul>
            {goodFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="fit-card careful">
          <p class="eyebrow">À éviter</p>
          <h2>Ce que je ne veux pas vendre.</h2>
          <ul>
            {badFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </section>

      <section class="section-pad process-section">
        <div class="section-heading">
          <p class="eyebrow">Méthode</p>
          <h2>Un déroulé court pour limiter la charge mentale.</h2>
        </div>
        <div class="card-grid four">
          {process.map(([number, title, text]) => (
            <article class="step-card">
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="exemples" class="section-pad examples-section">
        <div class="section-heading">
          <p class="eyebrow">Exemples anonymisés</p>
          <h2>Des problématiques réalistes, sans donnée client ni détail confidentiel.</h2>
        </div>
        <article class="case-study">
          <div>
            <p class="eyebrow">Étude de cas anonymisée</p>
            <h3>{caseStudy.title}</h3>
          </div>
          <div class="case-grid">
            <div>
              <strong>Contexte</strong>
              <p>{caseStudy.context}</p>
            </div>
            <div>
              <strong>Contrainte</strong>
              <p>{caseStudy.constraint}</p>
            </div>
            <div>
              <strong>Décision</strong>
              <p>{caseStudy.decision}</p>
            </div>
            <div>
              <strong>Résultat visé</strong>
              <p>{caseStudy.result}</p>
            </div>
          </div>
        </article>
        <div class="card-grid two">
          {examples.map((item) => (
            <article class="example-card">
              <h3>{item.title}</h3>
              <strong>Problème</strong>
              <p>{item.problem}</p>
              <strong>Réponse possible</strong>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Commencez par un brief court.</h2>
          <p>
            Le plus simple est d'utiliser l'assistant de cadrage ou de m'envoyer votre contexte, votre objectif,
            votre délai et les contraintes déjà connues.
          </p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={briefHref}>Préparer un brief</a>
          <a class="button ghost" href={mailHref}>Envoyer un email</a>
          <div class="social-links" aria-label="Liens secondaires">
            <a href={linkedinUrl} rel="noreferrer" target="_blank">LinkedIn</a>
            <a href={githubUrl} rel="noreferrer" target="_blank">GitHub</a>
          </div>
          <p>{contactEmail}</p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f6f3ed;
    --bg-soft: #ece6dc;
    --surface: #ffffff;
    --ink: #202124;
    --muted: #66615b;
    --line: #d8d0c4;
    --accent: #3f6f62;
    --accent-dark: #28483f;
    --warm: #a06245;
    --soft-green: #edf5f1;
    --soft-warm: #f7eee8;
    --shadow: 0 20px 54px rgba(32, 33, 36, 0.1);
    --radius: 8px;
    --page: 1160px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(20px, 5vw, 72px);
    border-bottom: 1px solid rgba(216, 208, 196, 0.78);
    background: rgba(246, 243, 237, 0.94);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: grid;
    gap: 2px;
    font-weight: 900;
  }

  .brand small,
  p,
  li {
    color: var(--muted);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(12px, 2.3vw, 28px);
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .nav-cta {
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--accent-dark);
    background: var(--soft-green);
  }

  .section-pad {
    padding: clamp(56px, 8vw, 104px) max(clamp(20px, 5vw, 72px), calc((100vw - var(--page)) / 2));
  }

  .hero {
    display: grid;
    min-height: calc(92vh - 73px);
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
    gap: clamp(32px, 6vw, 78px);
    align-items: center;
  }

  .eyebrow,
  .panel-label {
    margin: 0 0 14px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
  }

  h1 {
    max-width: 920px;
    font-size: clamp(2.45rem, 5vw, 5rem);
    line-height: 1;
  }

  h2 {
    font-size: clamp(1.9rem, 3.2vw, 3.1rem);
    line-height: 1.06;
  }

  h3 {
    font-size: 1.16rem;
    line-height: 1.25;
  }

  .lead {
    max-width: 780px;
    margin: 26px 0 0;
    font-size: clamp(1.08rem, 1.7vw, 1.28rem);
    line-height: 1.62;
  }

  .small-note,
  .section-heading p,
  .proof-panel p,
  .card p,
  .app-copy p,
  .app-card p,
  .step-card p,
  .example-card p,
  .contact-section p {
    line-height: 1.62;
  }

  .small-note {
    max-width: 760px;
    margin: 18px 0 0;
  }

  .hero-actions,
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 13px 18px;
    font-weight: 900;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .button.primary:hover {
    background: var(--accent-dark);
  }

  .button.secondary,
  .button.ghost {
    background: transparent;
  }

  .proof-panel,
  .card,
  .app-card,
  .strength-list article,
  .fit-card,
  .step-card,
  .example-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .proof-panel {
    padding: clamp(24px, 4vw, 34px);
    box-shadow: var(--shadow);
  }

  .proof-panel h2 {
    font-size: clamp(1.7rem, 2.5vw, 2.45rem);
  }

  .metric-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 26px;
  }

  .metric-grid span {
    display: grid;
    gap: 4px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 14px;
    color: var(--muted);
    background: var(--bg);
    font-weight: 800;
  }

  .metric-grid strong {
    color: var(--ink);
    font-size: 1.18rem;
  }

  .intro-section,
  .process-section {
    background: var(--surface);
  }

  .section-heading {
    max-width: 820px;
    margin-bottom: 34px;
  }

  .section-heading.narrow {
    max-width: 760px;
  }

  .section-heading p {
    margin: 18px 0 0;
    font-size: 1.06rem;
  }

  .card-grid {
    display: grid;
    gap: 16px;
  }

  .card-grid.three {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card-grid.four {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .card-grid.two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .card,
  .step-card,
  .example-card {
    padding: 24px;
  }

  .card p,
  .step-card p,
  .example-card p {
    margin: 14px 0 0;
  }

  .app-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.45fr);
    gap: clamp(24px, 5vw, 56px);
    align-items: center;
    background: var(--bg-soft);
  }

  .app-card {
    padding: 28px;
    box-shadow: var(--shadow);
  }

  .app-card .button {
    width: 100%;
    margin-top: 18px;
  }

  .product-preview {
    display: grid;
    gap: 10px;
    margin-top: 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 14px;
    background: var(--bg);
  }

  .product-preview div {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 10px;
  }

  .product-preview span {
    color: var(--muted);
    font-weight: 800;
  }

  .product-preview strong {
    text-align: right;
  }

  .product-preview ul {
    margin-top: 4px;
  }

  .status {
    display: inline-flex;
    margin-bottom: 18px;
    border-radius: 999px;
    padding: 7px 10px;
    color: var(--accent-dark);
    background: var(--soft-green);
    font-size: 0.82rem;
    font-weight: 900;
  }

  .strength-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .strength-list article {
    display: flex;
    gap: 14px;
    padding: 20px;
  }

  .strength-list span {
    display: grid;
    width: 30px;
    height: 26px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 999px;
    background: var(--soft-green);
    color: var(--accent-dark);
    font-size: 0.75rem;
    font-weight: 950;
  }

  .strength-list p {
    margin: 0;
    line-height: 1.55;
  }

  .fit-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    background: var(--bg-soft);
  }

  .fit-card {
    padding: clamp(24px, 4vw, 34px);
  }

  .fit-card.good {
    background: var(--soft-green);
  }

  .fit-card.careful {
    background: var(--soft-warm);
  }

  ul {
    display: grid;
    gap: 10px;
    margin: 22px 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    padding-left: 24px;
    line-height: 1.48;
  }

  li::before {
    position: absolute;
    left: 0;
    color: var(--accent);
    content: "+";
    font-weight: 900;
  }

  .step-card span {
    display: block;
    margin-bottom: 28px;
    color: rgba(160, 98, 69, 0.42);
    font-size: 2.6rem;
    font-weight: 950;
    line-height: 1;
  }

  .examples-section {
    background: var(--bg);
  }

  .case-study {
    display: grid;
    grid-template-columns: minmax(240px, 0.42fr) minmax(0, 1fr);
    gap: clamp(20px, 4vw, 42px);
    margin-bottom: 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(24px, 4vw, 34px);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .case-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .case-grid strong {
    display: block;
    margin-bottom: 8px;
  }

  .case-grid p {
    margin: 0;
    color: var(--muted);
    line-height: 1.62;
  }

  .example-card strong {
    display: block;
    margin-top: 18px;
  }

  .contact-section {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.45fr);
