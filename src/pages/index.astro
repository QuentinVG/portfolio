---
const contactEmail = "vialgouteyron@gmail.com";
const location = "Valence, Drôme, Ardèche et France à distance";
const githubUrl = "https://github.com/QuentinVG";
const linkedinUrl = "https://www.linkedin.com/in/qvg/";
const asset = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;

const mailSubject = "Demande de première estimation pour un site web";
const mailBody = `Bonjour Quentin,

Je souhaite vous contacter pour un projet de site web.

Mon activité :
Ma ville / zone :
Mon objectif principal :
Ai-je déjà un site ? :
Délai souhaité :
Budget approximatif :
Contenus déjà disponibles : textes / photos / logo / nom de domaine

Merci,`;
const mailHref = `mailto:${contactEmail}?subject=${encodeURIComponent(mailSubject)}&body=${encodeURIComponent(mailBody)}`;

const audiences = [
  "Praticiens bien-être",
  "Coachs",
  "Indépendants",
  "Associations locales",
  "Artisans soigneux",
  "Petites structures",
];

const goodFit = [
  "Vous voulez une présence en ligne claire sans vous prendre la tête.",
  "Vous avez besoin d'un site simple pour rassurer vos futurs clients.",
  "Vous voulez pouvoir envoyer un lien propre à quelqu'un.",
  "Vous voulez être accompagné sans jargon technique.",
  "Vous préférez une approche humaine, directe et bien cadrée.",
];

const badFit = [
  "Vous cherchez un gros site e-commerce ou une application complexe.",
  "Vous voulez une disponibilité immédiate tous les jours.",
  "Vous attendez une stratégie marketing complète.",
  "Vous n'avez pas encore clarifié votre activité, vos offres ou vos contenus.",
  "Vous cherchez uniquement le prix le plus bas possible.",
];

const deliverables = [
  {
    title: "Sites vitrines",
    text: "Une présence complète pour présenter votre activité, vos services et faciliter la prise de contact.",
  },
  {
    title: "Pages simples",
    text: "Une page claire pour présenter une offre, un événement ou démarrer avec une présence en ligne propre.",
  },
  {
    title: "Refontes légères",
    text: "Un site plus lisible, plus moderne et plus rassurant sans transformer le projet en chantier lourd.",
  },
  {
    title: "Suivi mensuel",
    text: "Un accompagnement léger pour garder votre site propre, à jour et vivant dans le temps.",
  },
];

const offers = [
  {
    name: "Page Simple",
    price: "à partir de 390 €",
    delay: "Délai indicatif : 1 à 2 semaines",
    bestFor: "Pour présenter une activité, une offre, un événement ou commencer avec une présence en ligne claire.",
    items: [
      "Une page responsive",
      "Présentation claire de l'activité",
      "Structure adaptée au mobile",
      "Bouton ou formulaire de contact",
      "Optimisation de base",
      "Accompagnement à la mise en ligne si besoin",
    ],
  },
  {
    name: "Site Vitrine",
    price: "à partir de 890 €",
    delay: "Délai indicatif : 3 à 4 semaines",
    highlighted: true,
    bestFor: "Pour une présence plus complète, plus rassurante et plus facile à partager.",
    items: [
      "3 à 5 pages",
      "Accueil, services, à propos, contact, mentions légales",
      "Design responsive",
      "Structure claire",
      "Performance correcte",
      "SEO de base raisonnable",
      "Formulaire de contact",
      "Accompagnement à la mise en ligne",
    ],
  },
  {
    name: "Suivi Mensuel",
    price: "à partir de 79 € / mois",
    delay: "Accompagnement léger, sans urgence 24/7",
    bestFor: "Pour garder un site propre, à jour et vivant, avec des délais raisonnables.",
    items: [
      "Petites modifications",
      "Corrections mineures",
      "Mises à jour de contenu",
      "Conseils simples",
      "Vérifications régulières",
      "Support léger",
    ],
  },
];

const pricingFactors = [
  "Nombre de pages",
  "Quantité de contenus à créer",
  "Photos ou visuels à préparer",
  "Besoin WordPress ou non",
  "Formulaire avancé",
  "Fonctionnalités spécifiques",
  "Accompagnement après mise en ligne",
  "Urgence du délai",
];

const process = [
  ["01", "Échange simple", "Vous m'expliquez votre activité, votre objectif et ce que le site doit permettre."],
  ["02", "Cadrage", "Je vous dis franchement ce qui est utile, ce qui ne l'est pas, le budget et le délai réalistes."],
  ["03", "Création", "Je construis une version propre, lisible sur mobile et adaptée à votre niveau d'autonomie."],
  ["04", "Retours", "On ajuste les textes, les priorités et les détails importants sans multiplier les réunions."],
  ["05", "Mise en ligne", "Je vous accompagne pour le domaine, l'hébergement et les derniers réglages si besoin."],
  ["06", "Suivi léger", "Vous pouvez ensuite demander des petites corrections ou mises à jour, sans support permanent."],
];

const demos = [
  {
    title: "Praticien bien-être",
    image: asset("projects/coach-web.png"),
    alt: "Exemple de site pour praticien bien-être",
    context: "Un praticien installé autour de Valence veut un site simple pour expliquer sa pratique et rassurer avant une première prise de contact.",
    problem: "Son activité est claire à l'oral, mais difficile à comprendre rapidement en ligne.",
    solution: "Une page d'accueil apaisante, une présentation courte, des informations pratiques et un bouton de contact visible.",
    result: "Le visiteur comprend à qui s'adresse l'accompagnement et peut contacter le praticien sans hésiter.",
  },
  {
    title: "Artisan local",
    image: asset("projects/artisan-web.png"),
    alt: "Exemple de site pour artisan local",
    context: "Un artisan soigneux en Drôme / Ardèche veut montrer son sérieux sans investir dans un site trop lourd.",
    problem: "Les clients potentiels ne voient pas clairement les prestations, la zone d'intervention ou la manière de demander un devis.",
    solution: "Une structure lisible avec services, zone couverte, exemples de réalisations et formulaire de demande.",
    result: "Le site devient un support de confiance à envoyer après un premier échange ou une recommandation.",
  },
  {
    title: "Association ou indépendant",
    image: asset("projects/restaurant-web.png"),
    alt: "Exemple de site pour association ou indépendant",
    context: "Une petite structure locale veut centraliser ses informations et éviter de répéter les mêmes réponses.",
    problem: "Horaires, lieu, activités, inscription et contact sont dispersés sur plusieurs supports.",
    solution: "Un site court, bien rangé, avec les informations essentielles et un contact facile.",
    result: "Les visiteurs trouvent plus vite les bonnes informations, et la structure paraît plus fiable.",
  },
];

const trustItems = [
  "Environ 9 ans d'expérience professionnelle en développement web.",
  "Un profil de lead developer PHP, avec une approche volontairement simple côté client.",
  "Un interlocuteur unique pour comprendre, construire et livrer le site.",
  "Des prix lisibles et un cadrage clair avant de commencer.",
  "Pas de jargon technique inutile, pas de promesse SEO miracle.",
  "Des sites simples, rapides, maintenables et adaptés à votre besoin réel.",
  "J'utilise des outils modernes pour travailler efficacement, mais chaque projet est relu, adapté et livré proprement.",
];

const contactChecklist = [
  "Votre activité",
  "Votre ville ou zone",
  "Votre objectif principal",
  "Si vous avez déjà un site",
  "Le délai souhaité",
  "Votre budget approximatif",
  "Ce que vous avez déjà : textes, photos, logo, nom de domaine",
];

const faqs = [
  {
    question: "Combien de temps prend un site ?",
    answer:
      "Une page simple prend généralement 1 à 2 semaines selon ma disponibilité et les contenus fournis. Un site vitrine prend plutôt 3 à 4 semaines selon le nombre de pages, les retours et la mise en ligne.",
  },
  {
    question: "Est-ce que je peux modifier mon site moi-même ?",
    answer:
      "Oui, si c'est important pour vous. Je peux choisir une solution comme WordPress. Si vous préférez un site très rapide et simple, je peux aussi gérer les petites modifications avec un suivi léger.",
  },
  {
    question: "Est-ce que l'hébergement est inclus ?",
    answer:
      "Non, l'hébergement et le nom de domaine restent à votre nom. Je peux vous conseiller une solution simple et vous accompagner pour la mise en ligne.",
  },
  {
    question: "Est-ce qu'il y a un engagement mensuel ?",
    answer:
      "Non. Le suivi mensuel est optionnel. Il sert à garder le site propre et vivant, mais ne correspond pas à une disponibilité immédiate 24/7.",
  },
  {
    question: "Est-ce que vous faites le logo ?",
    answer:
      "Je peux prévoir une base très simple si nécessaire, mais je ne remplace pas un graphiste ou un spécialiste de l'identité visuelle.",
  },
  {
    question: "Est-ce que vous travaillez à distance ?",
    answer:
      "Oui. Je suis basé à Valence et je peux travailler avec des structures en Drôme, Ardèche, Bourg-lès-Valence, Romans-sur-Isère, Guilherand-Granges, Tournon-sur-Rhône, Crest, ou à distance en France.",
  },
  {
    question: "Est-ce que je dois déjà avoir les textes et les photos ?",
    answer:
      "Pas forcément, mais il faut au moins une base. Je peux vous aider à structurer les textes, mais je ne propose pas une rédaction complète si rien n'est fourni.",
  },
  {
    question: "Est-ce que le référencement Google est inclus ?",
    answer:
      "Un SEO de base propre est inclus : structure des pages, titres, performance, mobile et métadonnées simples. Je ne promets pas une première place Google.",
  },
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="icon" href={asset("favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Quentin Vial-Gouteyron, développeur web à Valence, crée des sites simples, propres et rassurants pour praticiens, indépendants, associations et petites structures en Drôme, Ardèche et à distance."
    />
    <meta name="generator" content={Astro.generator} />
    <title>Quentin Vial-Gouteyron - Sites web simples à Valence</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Retour accueil">
        <span>Quentin Vial-Gouteyron</span>
        <small>Développeur web à Valence</small>
      </a>
      <nav aria-label="Navigation principale">
        <a href="#pour-qui">Pour qui</a>
        <a href="#offres">Offres</a>
        <a href="#profil">Profil</a>
        <a class="nav-cta" href="#contact">Estimation</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero section-pad">
        <div class="hero-copy">
          <p class="eyebrow">{location}</p>
          <h1>Un site simple, propre et rassurant pour présenter votre activité.</h1>
          <p class="lead">
            Développeur web local à Valence, j'aide les praticiens, indépendants, associations
            et petites structures à créer une présence en ligne claire, sans jargon technique.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={mailHref}>Demander une première estimation</a>
            <a class="button secondary" href="#offres">Voir les offres</a>
          </div>
          <p class="small-note">
            L'objectif n'est pas de faire un gros site compliqué. L'objectif est de vous aider à inspirer confiance,
            expliquer clairement ce que vous faites et faciliter la prise de contact.
          </p>
        </div>

        <aside class="hero-card" aria-label="Résumé de l'approche">
          <div class="availability">
            <span class="status-dot" aria-hidden="true"></span>
            Projets simples et bien cadrés
          </div>
          <dl>
            <div>
              <dt>Expérience</dt>
              <dd>9 ans env.</dd>
            </div>
            <div>
              <dt>Premier format</dt>
              <dd>dès 390 €</dd>
            </div>
            <div>
              <dt>Contact</dt>
              <dd>Email</dd>
            </div>
          </dl>
          <p>
            Je choisis la solution technique selon votre besoin : site simple ultra rapide, WordPress si vous voulez
            modifier le contenu vous-même, ou développement léger sur mesure.
          </p>
          <div class="scope-note">
            <strong>Le bon cadre</strong>
            <span>Un besoin clair, quelques contenus, des retours groupés, puis une mise en ligne propre.</span>
          </div>
        </aside>
      </section>

      <section id="pour-qui" class="audience-section section-pad compact">
        <div class="section-heading center">
          <p class="eyebrow">Pour qui ?</p>
          <h2>Des projets simples, humains et bien cadrés.</h2>
          <p>
            Je privilégie les personnes qui veulent une présence web claire, utile et rassurante,
            sans se lancer dans un projet lourd.
          </p>
        </div>
        <div class="audience-bar" aria-label="Publics concernés">
          {audiences.map((audience) => <span>{audience}</span>)}
        </div>
        <p class="local-note">
          Basé à Valence, je peux accompagner des projets en Drôme et Ardèche : Bourg-lès-Valence,
          Romans-sur-Isère, Guilherand-Granges, Tournon-sur-Rhône, Crest, et à distance si le cadre est clair.
        </p>
      </section>

      <section class="fit-section section-pad">
        <div class="fit-card good">
          <p class="eyebrow">Fait pour vous si</p>
          <h2>Vous voulez avancer simplement.</h2>
          <ul class="plain-list">
            {goodFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="fit-card careful">
          <p class="eyebrow">Pas forcément adapté si</p>
          <h2>Votre besoin demande un gros dispositif.</h2>
          <ul class="plain-list">
            {badFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </section>

      <section id="services" class="section-pad services-section">
        <div class="section-heading narrow">
          <p class="eyebrow">Ce que je crée</p>
          <h2>Des sites sobres, lisibles et faciles à maintenir.</h2>
          <p>
            Les clients non techniques doivent comprendre le résultat, pas la pile technique.
            Mon travail consiste à rendre votre activité claire et crédible en ligne.
          </p>
        </div>
        <div class="deliverable-grid">
          {deliverables.map((item) => (
            <article class="deliverable-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="offres" class="section-pad offers-section">
        <div class="section-heading center">
          <p class="eyebrow">Offres</p>
          <h2>Trois formats pour tester sans partir dans trop grand.</h2>
          <p>
            Les prix affichés sont des bases. Chaque projet est ajusté après un premier échange,
            selon le contenu, le délai et le niveau d'accompagnement souhaité.
          </p>
        </div>
        <div class="offer-grid">
          {offers.map((offer) => (
            <article class:list={["offer-card", { featured: offer.highlighted }]}>
              {offer.highlighted && <span class="offer-badge">Le plus rassurant</span>}
              <h3>{offer.name}</h3>
              <p class="price">{offer.price}</p>
              <p class="delay">{offer.delay}</p>
              <p class="best-for">{offer.bestFor}</p>
              <div class="offer-divider"></div>
              <ul class="check-list">
                {offer.items.map((item) => <li>{item}</li>)}
              </ul>
              <a class="button offer-button" href={mailHref}>Parler de ce besoin</a>
            </article>
          ))}
        </div>

        <aside class="secondary-offer">
          <div>
            <p class="eyebrow">À garder simple</p>
            <h3>Mini outil web sur mesure</h3>
            <p>
              Sur devis, à partir de 600 € : calculateur simple, formulaire avancé, générateur de devis,
              tableau de suivi ou automatisation légère. Je le propose seulement si le besoin est clair.
            </p>
          </div>
          <a href="#contact">En parler</a>
        </aside>
      </section>

      <section class="section-pad price-section">
        <div class="section-heading narrow">
          <p class="eyebrow">Prix transparents</p>
          <h2>Ce qui peut faire varier le budget.</h2>
          <p>
            Je préfère annoncer un cadre réaliste plutôt que vendre un prix trop bas qui devient frustrant ensuite.
          </p>
        </div>
        <div class="factor-grid">
          {pricingFactors.map((factor) => <span>{factor}</span>)}
        </div>
      </section>

      <section class="section-pad process-section">
        <div class="section-heading narrow">
          <p class="eyebrow">Process</p>
          <h2>Un cadre clair pour éviter la charge mentale.</h2>
          <p>
            Je limite les réunions longues, les urgences et les projets flous. Un projet simple fonctionne mieux
            quand chacun sait ce qu'il apporte et ce qu'il valide.
          </p>
        </div>
        <p class="process-note">
          Le but est de regrouper les décisions importantes, éviter les allers-retours permanents et garder un rythme compatible avec une activité complémentaire.
        </p>
        <div class="process-grid">
          {process.map(([number, title, text]) => (
            <article class="process-step">
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="exemples" class="section-pad demos-section">
        <div class="section-heading center">
          <p class="eyebrow">Exemples de projets possibles</p>
          <h2>Des exemples réalistes, pas de faux clients.</h2>
          <p>
            Ces exemples montrent des directions possibles. Ils ne sont pas présentés comme des missions client réelles.
          </p>
        </div>
        <div class="demo-grid">
          {demos.map((demo) => (
            <article class="demo-card">
              <img src={demo.image} alt={demo.alt} loading="lazy" />
              <div class="demo-content">
                <p class="category">Exemple possible</p>
                <h3>{demo.title}</h3>
                <div class="result-block">
                  <strong>Contexte</strong>
                  <p>{demo.context}</p>
                </div>
                <div class="result-block">
                  <strong>Problème</strong>
                  <p>{demo.problem}</p>
                </div>
                <div class="result-block">
                  <strong>Solution</strong>
                  <p>{demo.solution}</p>
                </div>
                <div class="result-block">
                  <strong>Résultat attendu</strong>
                  <p>{demo.result}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="profil" class="section-pad profile-section">
        <div class="profile-card">
          <p class="eyebrow">Qui suis-je ?</p>
          <h2>Je suis Quentin, développeur web à Valence.</h2>
          <p>
            Je travaille dans le développement web depuis environ 9 ans. Mon approche est simple :
            créer des sites propres, rapides et compréhensibles, sans noyer les clients dans la technique.
            J'aime les projets bien cadrés, les échanges clairs et les solutions utiles plutôt que les effets de mode.
          </p>
          <p>
            Mon expérience me permet de faire les choses proprement, mais mon objectif ici reste volontairement simple :
            accompagner des indépendants, praticiens, associations et petites structures sur des projets utiles, raisonnables
            et maintenables.
          </p>
        </div>
        <div class="trust-grid">
          {trustItems.map((item) => (
            <article>
              <span aria-hidden="true">OK</span>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="faq" class="section-pad faq-section">
        <div class="section-heading narrow">
          <p class="eyebrow">FAQ</p>
          <h2>Les questions normales avant de se lancer.</h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => (
            <details>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div>
          <p class="eyebrow">Contact guidé</p>
          <h2>Pour me contacter, envoyez-moi simplement ces éléments.</h2>
          <p>
            Pas besoin d'un cahier des charges complet. Une base claire suffit pour que je vous réponde
            avec une première estimation et une recommandation honnête.
          </p>
          <ul class="contact-list">
            {contactChecklist.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={mailHref}>M'envoyer mon besoin</a>
          <a class="button ghost" href={mailHref}>Demander une première estimation</a>
          <div class="social-links" aria-label="Liens secondaires">
            <a href={linkedinUrl} rel="noreferrer" target="_blank">LinkedIn</a>
            <a href={githubUrl} rel="noreferrer" target="_blank">GitHub</a>
          </div>
          <p class="email-note">{contactEmail}</p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f8f5ef;
    --bg-soft: #efe9df;
    --surface: #ffffff;
    --ink: #202124;
    --muted: #67615b;
    --line: #ddd4c8;
    --accent: #5d7768;
    --accent-dark: #334f43;
    --warm: #a96a4c;
    --soft-green: #edf4ef;
    --soft-warm: #f5ece5;
    --shadow: 0 18px 44px rgba(32, 33, 36, 0.09);
    --radius: 8px;
    --page: 1180px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    text-rendering: optimizeLegibility;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  p,
  h1,
  h2,
  h3,
  dd,
  dt {
    overflow-wrap: anywhere;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(20px, 5vw, 76px);
    border-bottom: 1px solid rgba(221, 212, 200, 0.78);
    background: rgba(247, 244, 239, 0.94);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: grid;
    gap: 2px;
    font-weight: 900;
  }

  .brand small {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(12px, 2.4vw, 28px);
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 760;
  }

  nav a:hover {
    color: var(--accent-dark);
  }

  .nav-cta {
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--accent-dark);
    background: var(--soft-green);
  }

  .section-pad {
    padding: clamp(58px, 8vw, 106px) max(clamp(20px, 5vw, 76px), calc((100vw - var(--page)) / 2));
  }

  .section-pad.compact {
    padding-top: clamp(38px, 6vw, 76px);
  }

  .hero {
    display: grid;
