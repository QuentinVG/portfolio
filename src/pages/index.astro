---
const contactEmail = "vialgouteyron@gmail.com";
const location = "Valence, Drome, Ardeche et France a distance";

const audiences = [
  "Artisans",
  "Independants",
  "Commerces locaux",
  "Associations",
  "Petites entreprises",
  "Coachs et prestataires",
];

const problems = [
  "Vous n'avez pas encore de site et vous voulez une presence claire.",
  "Votre site existe, mais il fait vieillir votre image.",
  "Sur mobile, vos clients ne trouvent pas vite les informations utiles.",
  "Votre site ne rassure pas assez avant une prise de contact.",
  "Vous avez peur de payer une agence trop chere pour un besoin simple.",
  "Vous ne voulez pas vous perdre dans la technique.",
];

const deliverables = [
  {
    title: "Sites vitrines",
    text: "Une presence complete pour presenter votre activite, vos services et faciliter les demandes.",
  },
  {
    title: "Landing pages",
    text: "Une page ciblee pour lancer une offre, un evenement ou tester une idee rapidement.",
  },
  {
    title: "Refontes simples",
    text: "Un site plus clair, plus moderne et plus lisible sans repartir dans un chantier inutile.",
  },
  {
    title: "Suivi mensuel",
    text: "Des petites modifications, corrections et conseils pour garder un site propre dans le temps.",
  },
  {
    title: "Mini outils web",
    text: "Un calculateur, formulaire avance, generateur de devis ou tableau de suivi quand un site ne suffit pas.",
  },
];

const offers = [
  {
    name: "Page Express",
    price: "a partir de 390 EUR",
    bestFor: "Pour presenter une activite, une offre, un evenement ou lancer une presence en ligne simple.",
    items: [
      "Une page responsive",
      "Presentation claire de l'activite",
      "Bouton ou formulaire de contact",
      "Optimisation mobile",
      "Mise en ligne possible",
    ],
  },
  {
    name: "Site Vitrine",
    price: "a partir de 790 EUR",
    highlighted: true,
    bestFor: "Pour une presence plus complete, credible et facile a partager a vos futurs clients.",
    items: [
      "3 a 5 pages",
      "Accueil, services, a propos, contact, mentions legales",
      "Design responsive",
      "Structure claire et SEO de base raisonnable",
      "Formulaire de contact",
      "Accompagnement mise en ligne",
    ],
  },
  {
    name: "Suivi Mensuel",
    price: "a partir de 79 EUR / mois",
    bestFor: "Pour garder un site propre, vivant et a jour sans devoir tout gerer seul.",
    items: [
      "Petites modifications",
      "Corrections mineures",
      "Mises a jour de contenu",
      "Verifications regulieres",
      "Conseils simples",
      "Support leger",
    ],
  },
];

const process = [
  ["01", "Echange rapide", "Vous m'expliquez votre activite, votre objectif et ce que le site doit permettre."],
  ["02", "Proposition claire", "Je vous indique une solution, un budget, un delai et les contenus necessaires."],
  ["03", "Creation", "Je construis une premiere version propre, lisible sur mobile et adaptee a votre besoin."],
  ["04", "Retours", "On ajuste les textes, les priorites et les details importants avant la livraison."],
  ["05", "Mise en ligne", "Je vous accompagne pour le domaine, l'hebergement et les derniers reglages."],
  ["06", "Suivi si besoin", "Vous pouvez ensuite demander des corrections, ajouts ou conseils ponctuels."],
];

const demos = [
  {
    title: "Artisan local",
    image: "/projects/artisan-web.png",
    alt: "Exemple de site pour artisan local",
    problem: "L'activite repose sur le bouche-a-oreille, mais le site ne montre pas clairement les services ni la zone d'intervention.",
    solution: "Une page de services lisible, des exemples de realisations, des avis et un bouton de demande de devis visible.",
    result: "Le visiteur comprend vite si l'artisan peut l'aider et sait comment le contacter.",
  },
  {
    title: "Coach ou independant",
    image: "/projects/coach-web.png",
    alt: "Exemple de site pour coach ou independant",
    problem: "L'offre est serieuse, mais difficile a expliquer simplement a une personne qui decouvre l'activite.",
    solution: "Une page qui clarifie l'accompagnement, rassure avec un parcours simple et met en avant la prise de rendez-vous.",
    result: "Une presence plus credible et un chemin plus direct vers le premier contact.",
  },
  {
    title: "Association ou commerce",
    image: "/projects/restaurant-web.png",
    alt: "Exemple de site pour association ou petit commerce",
    problem: "Les informations utiles sont dispersees: horaires, lieu, actualites, contact ou inscription.",
    solution: "Une structure courte avec les informations essentielles, une page contact et des appels a l'action simples.",
    result: "Moins de questions repetitives et une image plus professionnelle en ligne.",
  },
];

const trustItems = [
  "Environ 9 ans d'experience professionnelle en developpement web.",
  "Lead developer PHP: assez technique pour faire propre, assez pragmatique pour rester simple.",
  "Un interlocuteur unique, sans jargon inutile.",
  "Des tarifs annonces clairement avant de commencer.",
  "Des sites rapides, maintenables et adaptes au niveau d'autonomie souhaite.",
  "Des outils modernes pour travailler efficacement, avec une livraison relue et adaptee.",
];

const faqs = [
  {
    question: "Combien de temps prend un site ?",
    answer:
      "Une page simple peut souvent etre prete en quelques jours si les contenus sont disponibles. Un site vitrine prend plutot une a trois semaines selon le nombre de pages, les retours et la mise en ligne.",
  },
  {
    question: "Est-ce que je peux modifier mon site moi-meme ?",
    answer:
      "Oui, si c'est important pour vous, je peux choisir une solution comme WordPress. Si vous preferez un site tres rapide et simple, je peux aussi gerer les modifications ponctuelles pour vous.",
  },
  {
    question: "Est-ce que l'hebergement est inclus ?",
    answer:
      "Non, l'hebergement et le nom de domaine restent a votre nom. Je peux vous conseiller une solution simple et vous accompagner pour la mise en ligne.",
  },
  {
    question: "Est-ce qu'il y a un engagement mensuel ?",
    answer:
      "Non. Le suivi mensuel est optionnel. Vous pouvez aussi demander des modifications ponctuelles quand vous en avez besoin.",
  },
  {
    question: "Est-ce que vous faites le logo ?",
    answer:
      "Je peux faire une base tres simple si necessaire, mais je ne me presente pas comme graphiste ou studio de marque. Pour une identite complete, il vaut mieux travailler avec un specialiste.",
  },
  {
    question: "Est-ce que vous travaillez a distance ?",
    answer:
      "Oui. Je travaille a Valence, dans la Drome et l'Ardeche, mais je peux gerer un projet complet a distance partout en France.",
  },
  {
    question: "Est-ce que je dois deja avoir les textes et les photos ?",
    answer:
      "Pas forcement. C'est mieux si vous avez deja une base, mais je peux vous aider a structurer les textes et vous dire quelles photos seront utiles.",
  },
  {
    question: "Est-ce que le referencement Google est inclus ?",
    answer:
      "Un SEO de base propre est inclus: structure des pages, titres, performance, mobile et metadonnees simples. Je ne promets pas une premiere place Google.",
  },
];
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Quentin Vial-Gouteyron cree des sites vitrines, landing pages et maintenances legeres pour artisans, independants, petites entreprises, associations et commerces locaux."
    />
    <meta name="generator" content={Astro.generator} />
    <title>Quentin Vial-Gouteyron - Sites web simples et professionnels</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="#top" aria-label="Retour accueil">
        <span>Quentin</span>
        <small>Web freelance</small>
      </a>
      <nav aria-label="Navigation principale">
        <a href="#offres">Offres</a>
        <a href="#exemples">Exemples</a>
        <a href="#faq">FAQ</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero section-pad">
        <div class="hero-copy">
          <p class="eyebrow">{location}</p>
          <h1>Des sites web simples, rapides et professionnels pour les petites entreprises.</h1>
          <p class="lead">
            Developpeur web a Valence, j'aide les artisans, independants et petites structures a avoir
            une presence en ligne claire, credible et facile a maintenir.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={`mailto:${contactEmail}?subject=Demande de devis pour un site web`}>
              Demander un devis
            </a>
            <a class="button secondary" href="#offres">Voir les offres</a>
          </div>
          <p class="small-note">
            Pas de jargon inutile. Pas de promesse magique. Un site propre, adapte a votre besoin, avec un budget annonce avant de commencer.
          </p>
        </div>

        <aside class="hero-card" aria-label="Resume de l'offre">
          <div class="availability">
            <span class="status-dot" aria-hidden="true"></span>
            Disponible pour nouveaux projets
          </div>
          <dl>
            <div>
              <dt>Experience</dt>
              <dd>9 ans env.</dd>
            </div>
            <div>
              <dt>Premier site</dt>
              <dd>des 390 EUR</dd>
            </div>
            <div>
              <dt>Approche</dt>
              <dd>Claire et directe</dd>
            </div>
          </dl>
          <p>
            Je choisis la solution technique selon votre besoin: site simple ultra rapide, WordPress si vous voulez modifier le contenu vous-meme, ou developpement leger sur mesure.
          </p>
        </aside>
      </section>

      <section class="audience-bar" aria-label="Publics concernes">
        {audiences.map((audience) => <span>{audience}</span>)}
      </section>

      <section class="split-section section-pad">
        <div class="section-heading">
          <p class="eyebrow">Problemes frequents</p>
          <h2>Un site doit aider vos clients a comprendre, pas les perdre.</h2>
        </div>
        <div class="problem-grid">
          {problems.map((problem) => (
            <article class="problem-card">
              <span aria-hidden="true"></span>
              <p>{problem}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="services" class="section-pad services-section">
        <div class="section-heading narrow">
          <p class="eyebrow">Ce que je cree</p>
          <h2>Des livrables concrets, pas un catalogue technique.</h2>
          <p>
            L'objectif est simple: presenter votre activite, rassurer vos visiteurs et rendre la prise de contact evidente.
          </p>
        </div>
        <div class="deliverable-grid">
          {deliverables.map((item) => (
            <article class="deliverable-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="offres" class="section-pad offers-section">
        <div class="section-heading center">
          <p class="eyebrow">Offres</p>
          <h2>Trois points de depart simples.</h2>
          <p>Chaque projet est ajuste apres un premier echange, mais vous partez avec un ordre de prix clair.</p>
        </div>
        <div class="offer-grid">
          {offers.map((offer) => (
            <article class:list={["offer-card", { featured: offer.highlighted }]}>
              {offer.highlighted && <span class="offer-badge">Le plus courant</span>}
              <h3>{offer.name}</h3>
              <p class="price">{offer.price}</p>
              <p class="best-for">{offer.bestFor}</p>
              <ul class="check-list">
                {offer.items.map((item) => <li>{item}</li>)}
              </ul>
              <a class="button offer-button" href={`mailto:${contactEmail}?subject=${encodeURIComponent(`Demande - ${offer.name}`)}`}>
                Parler de ce besoin
              </a>
            </article>
          ))}
        </div>
        <aside class="secondary-offer">
          <div>
            <p class="eyebrow">Besoin specifique</p>
            <h3>Mini outil web sur mesure</h3>
            <p>
              A partir de 500 EUR: calculateur, formulaire avance, generateur de devis simple,
              tableau de suivi ou automatisation legere.
            </p>
          </div>
          <a href="#contact">En parler</a>
        </aside>
      </section>

      <section class="section-pad process-section">
        <div class="section-heading narrow">
          <p class="eyebrow">Process</p>
          <h2>Vous savez ou vous allez avant de payer.</h2>
        </div>
        <div class="process-grid">
          {process.map(([number, title, text]) => (
            <article class="process-step">
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="exemples" class="section-pad demos-section">
        <div class="section-heading center">
          <p class="eyebrow">Exemples de realisations possibles</p>
          <h2>Des demos realistes, pas de faux clients.</h2>
          <p>
            Ces exemples montrent des directions possibles. Ils ne sont pas presentes comme des missions client reelles.
          </p>
        </div>
        <div class="demo-grid">
          {demos.map((demo) => (
            <article class="demo-card">
              <img src={demo.image} alt={demo.alt} loading="lazy" />
              <div class="demo-content">
                <p class="category">Projet demo</p>
                <h3>{demo.title}</h3>
                <div class="result-block">
                  <strong>Probleme</strong>
                  <p>{demo.problem}</p>
                </div>
                <div class="result-block">
                  <strong>Solution</strong>
                  <p>{demo.solution}</p>
                </div>
                <div class="result-block">
                  <strong>Resultat attendu</strong>
                  <p>{demo.result}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad trust-section">
        <div class="trust-intro">
          <p class="eyebrow">Pourquoi me faire confiance</p>
          <h2>Une approche d'artisan du web: serieuse, claire, maintenable.</h2>
          <p>
            Je ne suis pas une grosse agence. Vous echangez directement avec la personne qui comprend,
            construit et livre le site.
          </p>
        </div>
        <div class="trust-grid">
          {trustItems.map((item) => (
            <article>
              <span aria-hidden="true">OK</span>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="faq" class="section-pad faq-section">
        <div class="section-heading narrow">
          <p class="eyebrow">FAQ</p>
          <h2>Les questions normales avant de se lancer.</h2>
        </div>
        <div class="faq-list">
          {faqs.map((faq) => (
            <details>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Decrivez-moi votre besoin, je vous reponds avec une premiere estimation.</h2>
          <p>
            Indiquez votre activite, le type de site souhaite, votre delai ideal et les contenus deja disponibles.
            Je vous dirai franchement ce qui est utile, ce qui ne l'est pas, et par quoi commencer.
          </p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={`mailto:${contactEmail}?subject=Demande de devis pour un site web`}>
            {contactEmail}
          </a>
          <div class="social-links" aria-label="Liens secondaires">
            <a href="#" aria-label="GitHub a ajouter plus tard">GitHub</a>
            <a href="#" aria-label="LinkedIn a ajouter plus tard">LinkedIn</a>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f6f3ed;
    --bg-soft: #ede8df;
    --surface: #ffffff;
    --ink: #1e1f22;
    --muted: #66615b;
    --line: #ded7cc;
    --accent: #126f73;
    --accent-dark: #0b4b4f;
    --warm: #b85f42;
    --success: #2f7d4a;
    --shadow: 0 18px 54px rgba(30, 31, 34, 0.1);
    --radius: 8px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  p,
  h1,
  h2,
  h3,
  dd,
  dt {
    overflow-wrap: anywhere;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(20px, 5vw, 76px);
    border-bottom: 1px solid rgba(222, 215, 204, 0.78);
    background: rgba(246, 243, 237, 0.92);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: grid;
    gap: 2px;
    font-weight: 900;
  }

  .brand small {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 700;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(12px, 2.4vw, 28px);
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 750;
  }

  nav a:hover {
    color: var(--accent-dark);
  }

  .section-pad {
    padding: clamp(58px, 8vw, 112px) clamp(20px, 5vw, 76px);
  }

  .hero {
    display: grid;
    min-height: calc(100vh - 73px);
    grid-template-columns: minmax(0, 1.22fr) minmax(300px, 0.78fr);
    gap: clamp(32px, 6vw, 84px);
    align-items: center;
  }

  .eyebrow,
  .category {
    margin: 0 0 14px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
  }

  h1 {
    max-width: 1060px;
    font-size: clamp(2.55rem, 6.4vw, 6.35rem);
    line-height: 0.96;
  }

  h2 {
    font-size: clamp(2rem, 4.4vw, 4rem);
    line-height: 1;
  }

  h3 {
    font-size: 1.18rem;
    line-height: 1.25;
  }

  .lead {
    max-width: 760px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: clamp(1.08rem, 2vw, 1.38rem);
    line-height: 1.58;
  }

  .small-note {
    max-width: 720px;
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .hero-actions,
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 13px 18px;
    font-weight: 900;
  }

  .button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .button.primary:hover {
    background: var(--accent-dark);
  }

  .button.secondary {
    background: transparent;
  }

  .hero-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow);
    padding: clamp(24px, 4vw, 34px);
  }

  .availability {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    border: 1px solid #cde1d3;
    border-radius: 999px;
    padding: 8px 12px;
    color: #235f39;
    background: #f1f8f3;
    font-size: 0.9rem;
    font-weight: 850;
  }

  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--success);
  }

  dl {
    display: grid;
    gap: 0;
    margin: 28px 0;
    border-top: 1px solid var(--line);
  }

  dl div {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
  }

  dt {
    color: var(--muted);
    font-weight: 750;
  }

  dd {
    margin: 0;
    font-weight: 900;
    text-align: right;
  }

  .hero-card p {
    margin: 0;
    color: var(--muted);
    line-height: 1.6;
  }

  .audience-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0 clamp(20px, 5vw, 76px) 28px;
  }

  .audience-bar span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 9px 13px;
    background: #fff;
    color: var(--muted);
    font-weight: 800;
  }

  .section-heading {
    max-width: 850px;
    margin-bottom: 34px;
  }

  .section-heading.narrow {
    max-width: 740px;
  }

  .section-heading.center {
    max-width: 780px;
    margin-right: auto;
    margin-left: auto;
    text-align: center;
  }

  .section-heading p:not(.eyebrow) {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 1.06rem;
    line-height: 1.62;
  }

  .split-section {
    display: grid;
    grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(28px, 5vw, 70px);
    align-items: start;
    background: var(--surface);
  }

  .problem-grid,
  .deliverable-grid,
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .problem-card,
  .deliverable-card,
  .offer-card,
  .process-step,
  .demo-card,
  .trust-grid article,
  details,
  .secondary-offer {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .problem-card {
    display: flex;
    gap: 14px;
    padding: 18px;
  }

  .problem-card span {
    width: 10px;
    height: 10px;
    flex: 0 0 auto;
    margin-top: 8px;
    border-radius: 999px;
    background: var(--warm);
  }

  .problem-card p,
  .deliverable-card p,
  .process-step p,
  .trust-grid p,
  .result-block p {
    margin: 0;
    color: var(--muted);
    line-height: 1.58;
  }

  .services-section,
  .process-section,
  .faq-section {
    background: var(--bg);
  }

  .deliverable-grid {
    grid-template-columns: repeat(5, minmax(0, 1fr));
  }

  .deliverable-card {
    min-height: 190px;
    padding: 22px;
