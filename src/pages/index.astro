---
import SiteHeader from "../components/SiteHeader.astro";
import { asset as buildAsset, contactEmail, githubUrl, linkedinUrl, mailto, repoUrl } from "../lib/site";

const asset = (path: string) => buildAsset(import.meta.env.BASE_URL, path);
const siteUrl = "https://quentinvg.github.io/portfolio/";
const pageTitle = "Quentin Vial-Gouteyron - Développeur PHP à Valence";
const pageDescription =
  "Développeur PHP à Valence. J'aide les TPE, PME et équipes métier à cadrer et construire des outils web simples, utiles et maintenables.";
const ogImageUrl = `${siteUrl}og.svg`;

const briefHref = asset("brief");
const methodHref = asset("method");
const briefSourceUrl = `${repoUrl}/blob/main/src/pages/brief.astro`;
const scoringSourceUrl = `${repoUrl}/blob/main/src/lib/briefScoring.ts`;
const immoradarPageUrl = "https://quentinvg.github.io/immoradar/";
const immoradarRepoUrl = "https://github.com/QuentinVG/immoradar";
const decisionclairePageUrl = "https://quentinvg.github.io/decisionclaire/";
const decisionclaireRepoUrl = "https://github.com/QuentinVG/decisionclaire";

const navItems = [
  { href: "#approche", label: "Approche" },
  { href: methodHref, label: "Méthode" },
  { href: "#preuves", label: "Preuves" },
  { href: "#projets", label: "Projets" },
  { href: "#exemples", label: "Exemples" },
  { href: briefHref, label: "Préparer un brief", cta: true },
];

const mailSubject = "Demande de cadrage pour un projet web";
const mailBody = `Bonjour Quentin,

Je vous contacte pour un projet web ou outil métier.

Contexte :
Objectif principal :
Utilisateurs concernés :
Données ou outils existants :
Délai souhaité :
Budget approximatif :
Ce qui est déjà prêt :

Merci,`;
const mailHref = mailto(mailSubject, mailBody);

const fitCards = [
  {
    title: "Un besoin encore flou",
    text: "Je vous aide à séparer le problème réel, les envies de confort et ce qui doit absolument exister en V1.",
  },
  {
    title: "Un outil interne trop artisanal",
    text: "Excel, mails, copier-coller, statuts suivis à la main : je transforme le flux en écran simple et exploitable.",
  },
  {
    title: "Un site qui doit servir",
    text: "Pas un site décoratif. Une page claire, rapide, lisible, avec un objectif : rassurer, qualifier ou déclencher un contact.",
  },
];

const proofItems = [
  "Le formulaire calcule un score de complexité lisible.",
  "Les risques sortent avant le devis, pas après le lancement.",
  "La synthèse peut être envoyée par email sans créer de compte.",
];

const workExamples = [
  {
    title: "Import métier contrôlé",
    problem: "Un fichier doit être importé sans doublons, sans erreurs muettes et sans casser le process existant.",
    answer: "Contrôle des colonnes, messages lisibles, résumé d'import et traces minimales pour reprendre proprement.",
  },
  {
    title: "Workflow de validation",
    problem: "Les demandes passent par mails, messages et fichiers. Personne ne sait quel statut fait foi.",
    answer: "Statuts courts, rôles clairs, historique utile, filtres et export. Le reste attend une vraie V2.",
  },
  {
    title: "Écran lent ou confus",
    problem: "Trop de données à l'écran, pas assez de priorités, et des décisions qui prennent plus de temps qu'elles ne devraient.",
    answer: "Tri des informations, filtres utiles, requêtes allégées et interface plus directe.",
  },
];

const frameGood = [
  "Problème métier concret et utile.",
  "Une personne disponible pour arbitrer.",
  "Périmètre écrit avant de démarrer.",
  "Retours regroupés, pas au fil de l'eau.",
  "Délais compatibles avec soir et week-end.",
];

const frameBad = [
  "Délai très court ou besoin de support quotidien.",
  "Projet large type marketplace, gros e-commerce ou SaaS complet.",
  "Objectif encore difficile à mesurer.",
  "Budget et attentes à remettre au même niveau.",
  "Maintenance à prévoir avec un cadre clair.",
];

const visualExamples = [
  {
    image: asset("projects/restaurant-web.png"),
    title: "Restaurant",
    text: "Direction visuelle pour une activité locale : menu, horaires, lieu, contact.",
    alt: "Maquette de site restaurant affichée sur ordinateur portable et mobile",
  },
  {
    image: asset("projects/coach-web.png"),
    title: "Coach",
    text: "Page de service sobre : promesse, preuves, prise de contact, contenu lisible.",
    alt: "Maquette de site de coach sur ordinateur portable et mobile",
  },
  {
    image: asset("projects/artisan-web.png"),
    title: "Artisan",
    text: "Exemple plus terrain : prestations, réalisations, zone d'intervention.",
    alt: "Maquette de site artisan affichée sur ordinateur portable et tablette",
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: "Quentin Vial-Gouteyron",
  url: siteUrl,
  image: ogImageUrl,
  email: contactEmail,
  areaServed: ["Valence", "Drôme", "Ardèche", "France"],
  description: pageDescription,
  founder: {
    "@type": "Person",
    name: "Quentin Vial-Gouteyron",
    jobTitle: "Développeur PHP",
    sameAs: [linkedinUrl, githubUrl],
  },
  knowsAbout: ["PHP", "outils métier", "cadrage technique", "sites web", "automatisation"],
};
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="icon" href={asset("favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <SiteHeader subtitle="Développeur PHP à Valence" brandHref="#top" navItems={navItems} />

    <main id="top">
      <section class="hero section-pad">
        <div class="hero-copy">
          <p class="eyebrow">Valence, Drôme, Ardèche et distance</p>
          <h1>Je transforme des idées floues en outils web propres, rapides et utilisables.</h1>
          <p class="lead">
            Je suis Quentin, développeur PHP depuis environ 9 ans. J’aide quand un besoin métier devient trop important
            pour rester dans Excel, mais mérite encore une V1 simple plutôt qu’un gros projet mal cadré.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={briefHref}>Préparer mon brief</a>
            <a class="button secondary" href={mailHref}>Me contacter</a>
          </div>
          <p class="small-note">
            Je préfère réduire un périmètre que vendre une promesse fragile. Un bon outil commence souvent plus petit
            que l’idée de départ, puis devient fiable.
          </p>
        </div>

        <aside class="product-board" aria-label="Exemple de cadrage">
          <div class="board-topline">
            <span class="status-dot" aria-hidden="true"></span>
            Cadrage avant devis
          </div>
          <div class="board-score">
            <div>
              <p>Demande</p>
              <strong>À clarifier</strong>
            </div>
            <span>V1</span>
          </div>
          <div class="board-meter" aria-hidden="true"><span></span></div>
          <div class="board-columns">
            <div>
              <h3>Risque</h3>
              <ul>
                <li>Rôles non décidés</li>
                <li>Données à nettoyer</li>
                <li>Délai trop serré</li>
              </ul>
            </div>
            <div>
              <h3>V1 raisonnable</h3>
              <ul>
                <li>Formulaire</li>
                <li>Statuts</li>
                <li>Export simple</li>
              </ul>
            </div>
          </div>
          <div class="board-footer">
            <span>Décision saine</span>
            <strong>Construire moins, mais livrer vraiment</strong>
          </div>
        </aside>
      </section>

      <section id="approche" class="section-pad intro-section">
        <div class="section-heading">
          <p class="eyebrow">Ce que je fais vraiment</p>
          <h2>Je ne vends pas du mystère technique. Je rends un besoin plus net, puis je code ce qui mérite de l'être.</h2>
          <p>
            Mon travail commence souvent par des questions simples : qui utilise l'outil, quelle donnée fait foi, qu'est-ce
            qui bloque aujourd'hui, et qu'est-ce qui peut attendre.
          </p>
        </div>
        <div class="card-grid three">
          {fitCards.map((item) => (
            <article class="card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad human-section">
        <div class="human-copy">
          <p class="eyebrow">La façon de travailler</p>
          <h2>Simple, direct, avec les contraintes dites avant.</h2>
          <p>
            Je travaille avec une disponibilité limitée, donc je ne peux pas promettre de l'urgence permanente. En
            revanche, je peux poser un cadre propre, livrer une V1 utile et documenter ce qu'il faut pour ne pas vous
            laisser avec une boîte noire.
          </p>
        </div>
        <div class="profile-card">
          <div>
            <strong>9 ans</strong>
            <span>développement web PHP</span>
          </div>
          <div>
            <strong>Lead dev</strong>
            <span>cadrage, revues, debug, arbitrages</span>
          </div>
          <div>
            <strong>IA</strong>
            <span>utilisée comme accélérateur, pas comme pilote automatique</span>
          </div>
        </div>
      </section>

      <section id="preuves" class="section-pad proof-section">
        <div class="section-heading">
          <p class="eyebrow">Preuves</p>
          <h2>Le portfolio contient déjà un petit outil, pas seulement une page qui dit que je sais en faire.</h2>
          <p>
            L'assistant de cadrage montre ma manière de penser : transformer une demande vague en risques, questions,
            périmètre V1 et résumé exploitable.
          </p>
        </div>
        <div class="proof-grid">
          <article class="app-card">
            <span class="status">Demo disponible</span>
            <h3>Assistant de cadrage</h3>
            <p>Un formulaire client-side qui aide à préparer un brief sans compte, sans base de données et sans collecte cachée.</p>
            <div class="product-preview" aria-label="Apercu du resultat genere">
              <div>
                <span>Lecture</span>
                <strong>Complexité moyenne</strong>
              </div>
              <div>
                <span>Sortie</span>
                <strong>V1 + risques + questions</strong>
              </div>
              <ul>
                {proofItems.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div class="button-row">
              <a class="button primary" href={briefHref}>Tester l'assistant</a>
              <a class="button secondary" href={briefSourceUrl} rel="noreferrer" target="_blank">Voir le code</a>
            </div>
          </article>

          <article class="code-card">
            <p class="eyebrow">Transparence</p>
            <h3>Le code est lisible et public.</h3>
            <p>
              Pas de démo magique. La logique de scoring est dans le dépôt, avec des règles simples que vous pouvez lire.
            </p>
            <pre aria-label="Extrait de sortie de cadrage"><code>risques:
  - délai court
  - données à valider
  - rôles à cadrer

v1:
  - parcours principal
  - suivi des statuts
  - export simple</code></pre>
            <a class="text-link" href={scoringSourceUrl} rel="noreferrer" target="_blank">Lire la logique de scoring</a>
          </article>
        </div>
      </section>

      <section id="projets" class="section-pad project-section">
        <div class="section-heading">
          <p class="eyebrow">Projet complet</p>
          <h2>ImmoRadar : l’app Laravel qui montre le mieux mon niveau produit.</h2>
          <p>
            Assistant de visite et de décision immobilière anti-coup de cœur : projets, biens, checklist mobile, coût
            réel mensuel, alertes, scoring expliqué, comparateur, documents avant offre et rapports PDF.
          </p>
        </div>
        <div class="project-showcase">
          <article class="project-panel">
            <span class="status">Laravel / Blade / Tailwind</span>
            <h3>Comparer un bien sans décider uniquement au ressenti.</h3>
            <p>
              L'utilisateur ajoute les biens manuellement. Aucune IA, aucun scraping, aucune fausse automatisation :
              l'app aide surtout à rendre la décision plus calme et plus lisible.
            </p>
            <div class="project-metrics" aria-label="Fonctionnalités ImmoRadar">
              <div><strong>4</strong><span>scores expliqués</span></div>
              <div><strong>PDF</strong><span>rapport décision</span></div>
              <div><strong>Tests</strong><span>services critiques</span></div>
            </div>
            <div class="button-row">
              <a class="button primary" href={immoradarPageUrl} rel="noreferrer" target="_blank">Voir la page projet</a>
              <a class="button secondary" href={immoradarRepoUrl} rel="noreferrer" target="_blank">Voir le repo</a>
            </div>
          </article>
          <aside class="decision-preview" aria-label="Aperçu ImmoRadar">
            <div>
              <span>Verdict expliqué</span>
              <strong>Pourquoi ce bien mérite d'être gardé ou écarté</strong>
            </div>
            <div>
              <span>Coût réel mensuel</span>
              <strong>Crédit, charges, taxe, énergie, travaux</strong>
            </div>
            <div class="risk-line">
              <span>Alertes</span>
              <strong>DPE, budget, trajet, infos manquantes</strong>
            </div>
          </aside>
        </div>
      </section>

      <section class="section-pad project-section decisionclaire-section">
        <div class="section-heading">
          <p class="eyebrow">Projet personnel</p>
          <h2>DécisionClaire : des calculateurs Laravel pour décider plus calmement.</h2>
          <p>
            Application fullstack d'outils gratuits pour clarifier des décisions d'argent du quotidien : achat
            raisonnable, reste à vivre, objectif épargne, abonnements et comparaison de scénarios.
          </p>
        </div>
        <div class="project-showcase">
          <article class="project-panel">
            <span class="status">Laravel 13 / Breeze / DomPDF</span>
            <h3>Un assistant de décision sans compte bancaire connecté.</h3>
            <p>
              Les outils sont utilisables sans compte. L'utilisateur peut sauvegarder ses simulations s'il se connecte,
              exporter un PDF, copier un résumé et comprendre le verdict sans jargon financier.
            </p>
            <div class="project-metrics" aria-label="Fonctionnalités DécisionClaire">
              <div><strong>6</strong><span>outils publics</span></div>
              <div><strong>PDF</strong><span>exports privés</span></div>
              <div><strong>CI</strong><span>tests, Pint, Larastan</span></div>
            </div>
            <div class="button-row">
              <a class="button primary" href={decisionclairePageUrl} rel="noreferrer" target="_blank">Voir la vitrine</a>
              <a class="button secondary" href={decisionclaireRepoUrl} rel="noreferrer" target="_blank">Voir le repo</a>
            </div>
          </article>
          <aside class="decision-preview decisionclaire-preview" aria-label="Aperçu DécisionClaire">
            <div>
              <span>J'achète ou pas ?</span>
              <strong>Achat raisonnable, limite, impulsif probable ou risqué</strong>
            </div>
            <div>
              <span>Reste à vivre</span>
              <strong>Mensuel, hebdomadaire, journalier et marge de sécurité</strong>
            </div>
            <div class="risk-line">
              <span>Compte optionnel</span>
              <strong>Sauvegarde, duplication, suppression et export PDF</strong>
            </div>
          </aside>
        </div>
      </section>

      <section id="exemples" class="section-pad examples-section">
        <div class="section-heading">
          <p class="eyebrow">Exemples</p>
            <h2>Les sujets où je peux apporter quelque chose sans inventer une usine.</h2>
        </div>
        <div class="example-grid">
          {workExamples.map((item) => (
            <article class="example-card">
              <h3>{item.title}</h3>
              <strong>Problème</strong>
              <p>{item.problem}</p>
              <strong>Réponse utile</strong>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad visual-section">
        <div class="section-heading">
          <p class="eyebrow">Visuels</p>
          <h2>Des directions visuelles propres, mais je ne les présente pas comme de fausses références client.</h2>
          <p>
            Ces maquettes montrent le niveau de finition visé pour des activités locales. Pour un outil métier, je
            privilégie surtout la clarté, la vitesse et les écrans qui se relisent vite.
          </p>
        </div>
        <div class="visual-grid">
          {visualExamples.map((item) => (
            <article class="visual-card">
              <img src={item.image} alt={item.alt} loading="lazy" />
              <div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section id="cadre" class="section-pad fit-section">
        <div class="fit-card good">
          <p class="eyebrow">Bon cadre</p>
          <h2>Là où je peux être utile.</h2>
          <ul>
            {frameGood.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="fit-card careful">
          <p class="eyebrow">À clarifier tôt</p>
          <h2>Les points qui peuvent faire déraper un petit projet.</h2>
          <ul>
            {frameBad.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </section>

      <section class="section-pad process-section">
        <div class="section-heading">
          <p class="eyebrow">Méthode</p>
          <h2>Le déroulé est volontairement court.</h2>
          <p>
            Clarifier, réduire, construire, livrer. Le reste dépend du projet, du budget et de ce que la V1 apprend
            vraiment.
          </p>
        </div>
        <div class="timeline-grid">
          <article class="step-card">
            <span>01</span>
            <h3>Comprendre</h3>
            <p>Objectif, utilisateurs, données, contraintes, blocages.</p>
          </article>
          <article class="step-card">
            <span>02</span>
            <h3>Réduire</h3>
            <p>V1, hors périmètre, risques et questions à trancher.</p>
          </article>
          <article class="step-card">
            <span>03</span>
            <h3>Construire</h3>
            <p>Code proportionné, maintenable, testé selon le risque.</p>
          </article>
          <article class="step-card">
            <span>04</span>
            <h3>Livrer</h3>
            <p>Retours regroupés, corrections utiles, suite décidée calmement.</p>
          </article>
        </div>
        <div class="method-link">
          <a class="button secondary" href={methodHref}>Voir la méthode détaillée</a>
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Commencez par le contexte, pas par une liste de fonctionnalités.</h2>
          <p>
            Envoyez le problème, les utilisateurs, les données, le délai, le budget approximatif et ce qui existe déjà.
            S'il faut réduire le périmètre, je vous le dirai.
          </p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={briefHref}>Préparer un brief</a>
          <a class="button ghost" href={mailHref}>Envoyer un email</a>
          <div class="social-links" aria-label="Liens secondaires">
            <a href={linkedinUrl} rel="noreferrer" target="_blank">LinkedIn</a>
            <a href={githubUrl} rel="noreferrer" target="_blank">GitHub</a>
          </div>
          <p>{contactEmail}</p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #fbfaf5;
    --bg-soft: #eef8f5;
    --surface: #ffffff;
    --ink: #101827;
    --muted: #596575;
    --line: #d8e4df;
    --accent: #0f766e;
    --accent-dark: #134e4a;
    --cool: #2563eb;
    --warm: #c56a2d;
    --soft-green: #e9f4ef;
    --soft-warm: #fff1e6;
    --shadow: 0 22px 60px rgba(15, 23, 42, 0.10);
    --shadow-strong: 0 32px 90px rgba(15, 118, 110, 0.18);
    --radius: 8px;
    --page: 1160px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background:
      linear-gradient(135deg, rgba(15, 118, 110, 0.10), transparent 30%),
      linear-gradient(225deg, rgba(197, 106, 45, 0.12), transparent 28%),
      var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  p,
  li {
    color: var(--muted);
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
  }

  h1 {
    max-width: 940px;
    font-size: clamp(2.35rem, 4.25vw, 4.35rem);
    line-height: 1.02;
  }

  h2 {
    font-size: clamp(1.85rem, 3vw, 3rem);
    line-height: 1.07;
  }

  h3 {
    font-size: 1.16rem;
    line-height: 1.25;
  }

  .section-pad {
    padding: clamp(56px, 8vw, 104px) max(clamp(20px, 5vw, 72px), calc((100vw - var(--page)) / 2));
  }

  .hero {
    display: grid;
    min-height: calc(92vh - 73px);
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.72fr);
    gap: clamp(32px, 6vw, 78px);
    align-items: center;
    position: relative;
  }

  .hero::before {
    position: absolute;
    inset: 32px max(clamp(20px, 5vw, 72px), calc((100vw - var(--page)) / 2));
    z-index: -1;
    border: 1px solid rgba(15, 118, 110, 0.10);
    border-radius: var(--radius);
    background-image:
      linear-gradient(rgba(15, 118, 110, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 118, 110, 0.08) 1px, transparent 1px);
    background-size: 36px 36px;
    content: "";
    mask-image: linear-gradient(90deg, black, transparent 86%);
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

