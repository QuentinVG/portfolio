---
import SiteHeader from "../components/SiteHeader.astro";
import { asset as buildAsset, contactEmail, githubUrl, linkedinUrl, mailto, repoUrl } from "../lib/site";

const briefSourceUrl = `${repoUrl}/blob/main/src/pages/brief.astro`;
const scoringSourceUrl = `${repoUrl}/blob/main/src/lib/briefScoring.ts`;
const asset = (path: string) => buildAsset(import.meta.env.BASE_URL, path);

const briefHref = asset("brief");
const methodHref = asset("method");
const navItems = [
  { href: "#approche", label: "Approche" },
  { href: methodHref, label: "Méthode" },
  { href: "#cadre", label: "Cadre" },
  { href: "#exemples", label: "Exemples" },
  { href: briefHref, label: "Préparer un brief", cta: true },
];
const mailSubject = "Demande de cadrage pour un projet web";
const mailBody = `Bonjour Quentin,

Je vous contacte pour un projet web ou outil métier.

Contexte :
Objectif principal :
Utilisateurs concernés :
Données ou outils existants :
Délai souhaité :
Budget approximatif :
Ce qui est déjà prêt :

Merci,`;
const mailHref = mailto(mailSubject, mailBody);

const useCases = [
  {
    title: "Site ou espace utile",
    text: "Une présence web claire, mais pensée autour d'un objectif concret : informer, qualifier, rassurer ou déclencher une prise de contact.",
  },
  {
    title: "Outil métier ciblé",
    text: "Un formulaire avancé, un tableau de suivi, un mini back-office ou un flux simple pour réduire les tâches répétitives.",
  },
  {
    title: "Cadrage technique",
    text: "Une demande encore mouvante transformée en périmètre, priorités, risques, questions et première estimation réaliste.",
  },
];

const strengths = [
  "Environ 9 ans d'expérience professionnelle en développement web PHP.",
  "Habitude des environnements métier, des personnalisations client, des données et des contraintes de maintenance.",
  "Analyse de specs, chiffrage, conception technique, debug, tests, commits, revues et suivi de tickets/projets.",
  "Approche lead dev : découper une demande, rendre les risques visibles, arbitrer et sécuriser la qualité.",
  "Utilisation de l'IA comme accélérateur d'analyse et de développement, avec relecture technique systématique.",
];

const goodFit = [
  "Problème métier réel, utile et découpable.",
  "Référent disponible pour arbitrer les décisions.",
  "Périmètre écrit avant le démarrage.",
  "Retours regroupés plutôt que demandes au fil de l'eau.",
  "Projet compatible avec une disponibilité soir/week-end.",
];

const badFit = [
  "Urgence permanente ou support quotidien attendu.",
  "Gros e-commerce, marketplace ou plateforme SaaS complète.",
  "Projet sans périmètre, sans référent ou sans objectif mesurable.",
  "Budget très bas avec attentes de produit complet.",
  "Maintenance ouverte sans règles de fonctionnement.",
];

const operatingFrame = [
  "Interventions courtes, cadrées et compatibles avec une disponibilité soir/week-end.",
  "Pas d'urgence permanente : les délais doivent rester réalistes.",
  "Retours regroupés pour éviter les micro-allers-retours.",
  "Une V1 utile vaut mieux qu'un grand périmètre instable.",
];

const businessProblems = [
  {
    title: "Données et imports",
    text: "Contrôler des fichiers, éviter les doubles saisies, afficher des erreurs lisibles et garder une trace exploitable.",
  },
  {
    title: "Suivi et validation",
    text: "Remplacer les échanges dispersés par des statuts, rôles, commentaires, historiques et actions claires.",
  },
  {
    title: "Écrans métier",
    text: "Rendre un écran plus rapide, plus lisible, mieux filtré et plus adapté aux décisions quotidiennes.",
  },
  {
    title: "Automatisations sobres",
    text: "Générer un document, préparer un export, synchroniser une information ou fiabiliser une tâche répétitive.",
  },
];

const deliverableExamples = [
  {
    title: "Brief de cadrage",
    text: "Objectif, utilisateurs, données, contraintes, risques et questions à trancher avant développement.",
  },
  {
    title: "Découpage V1 / V2",
    text: "Ce qui doit être livré tout de suite, ce qui peut attendre et ce qui doit rester hors périmètre.",
  },
  {
    title: "Mini backlog",
    text: "Liste courte de tâches compréhensibles, priorisées et assez précises pour estimer.",
  },
  {
    title: "Estimation par lots",
    text: "Une lecture plus saine qu'un gros prix global sur un besoin encore mouvant.",
  },
];

const examples = [
  {
    title: "Import métier contrôlé",
    problem: "Des données doivent être récupérées depuis un fichier ou un outil existant sans casser le processus.",
    answer: "Contrôles, erreurs lisibles, résumé d'import et garde-fous pour éviter les doubles saisies.",
  },
  {
    title: "Workflow de validation",
    problem: "Une équipe perd du temps parce que les demandes passent par trop de messages et validations informelles.",
    answer: "États clairs, actions autorisées, historique et notifications simples pour rendre le flux lisible.",
  },
  {
    title: "Écran lent ou confus",
    problem: "Un écran métier charge trop de données, mélange les informations et ralentit les décisions.",
    answer: "Tri des priorités, requêtes allégées, filtres utiles et interface plus directe.",
  },
  {
    title: "Mini back-office",
    problem: "Une petite structure suit encore ses demandes dans des fichiers ou emails dispersés.",
    answer: "Un outil simple pour centraliser, filtrer, commenter et suivre l'avancement sans construire une usine.",
  },
];

const process = [
  ["01", "Clarifier", "Comprendre l'objectif, les utilisateurs, les données et ce qui bloque vraiment."],
  ["02", "Cadrer", "Écrire un périmètre court, les hypothèses, les risques et les choix à valider."],
  ["03", "Construire", "Développer une version utile, maintenable, testable et adaptée au budget."],
  ["04", "Livrer", "Regrouper les retours, corriger proprement et documenter le minimum nécessaire."],
];

const previewRisks = ["Délai court", "Données à valider", "Rôles à cadrer"];
const previewScope = ["Parcours V1", "Suivi des statuts", "Export simple"];

const caseStudy = {
  title: "Flux de demandes internes trop dispersé",
  context:
    "Une petite équipe suit des demandes dans des emails, fichiers et échanges informels. L'information existe, mais personne ne sait vraiment quel élément fait foi.",
  constraint:
    "Le besoin paraît simple au départ, mais il touche aux statuts, aux validations, aux droits et à l'historique. Sans cadrage, le projet peut vite devenir un mini ERP.",
  decision:
    "Réduire la V1 à un suivi clair : création de demande, statut, commentaire, filtre, historique minimal et export. Le reste passe en options à arbitrer.",
  result:
    "Un périmètre plus court, plus facile à estimer, avec moins de risques de dérive et une première version réellement livrable.",
};
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="icon" href={asset("favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Quentin Vial-Gouteyron, développeur web PHP à Valence, aide les TPE, PME et équipes métier à cadrer, construire ou améliorer des outils web utiles et maintenables."
    />
    <meta name="generator" content={Astro.generator} />
    <title>Quentin Vial-Gouteyron - Développeur PHP, sites utiles et outils métier</title>
  </head>
  <body>
    <SiteHeader subtitle="Développeur PHP à Valence" brandHref="#top" navItems={navItems} />

    <main id="top">
      <section class="hero section-pad">
        <div class="hero-copy">
          <p class="eyebrow">Valence, Drôme, Ardèche et France à distance</p>
          <h1>Je transforme vos besoins métier en outils web simples et maintenables.</h1>
          <p class="lead">
            J'aide les TPE, PME et équipes métier à clarifier, construire ou améliorer un site utile, un mini outil web
            ou une automatisation légère, sans complexité inutile.
          </p>
          <div class="hero-actions">
            <a class="button primary" href={briefHref}>Préparer mon brief</a>
            <a class="button secondary" href={mailHref}>Me contacter</a>
          </div>
          <p class="small-note">
            Mon intérêt n'est pas de vendre un site de plus, mais de construire le bon petit outil quand il apporte
            vraiment quelque chose.
          </p>
        </div>

        <aside class="product-board" aria-label="Aperçu de l'assistant de cadrage">
          <div class="board-topline">
            <span class="status-dot" aria-hidden="true"></span>
            Brief exploitable
          </div>
          <div class="board-score">
            <div>
              <p>Complexité</p>
              <strong>Moyenne</strong>
            </div>
            <span>15/37</span>
          </div>
          <div class="board-meter" aria-hidden="true"><span></span></div>
          <div class="board-columns">
            <div>
              <h3>Risques</h3>
              <ul>
                {previewRisks.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div>
              <h3>V1</h3>
              <ul>
                {previewScope.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
          <div class="board-footer">
            <span>Format conseillé</span>
            <strong>Petit outil livré par version</strong>
          </div>
        </aside>
      </section>

      <section id="approche" class="section-pad intro-section">
        <div class="section-heading">
          <p class="eyebrow">Positionnement</p>
          <h2>Pas seulement un site vitrine. Un problème métier compris, réduit et construit proprement.</h2>
          <p>
            Un site simple peut être pertinent. Ma vraie valeur est de comprendre le fonctionnement métier, poser les
            limites, repérer les risques et construire une solution sobre qui reste maintenable.
          </p>
        </div>
        <div class="card-grid three">
          {useCases.map((item) => (
            <article class="card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad">
        <div class="section-heading">
          <p class="eyebrow">Problèmes traités</p>
          <h2>Des cas concrets où un petit outil bien pensé peut changer le quotidien.</h2>
          <p>
            Je suis plus utile quand il faut relier le besoin, les données, les usages et la maintenance. Pas seulement
            poser une interface sur une idée.
          </p>
        </div>
        <div class="card-grid four">
          {businessProblems.map((item) => (
            <article class="card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad app-section">
        <div class="app-copy">
          <p class="eyebrow">Démo interactive</p>
          <h2>Essayez l'assistant de cadrage.</h2>
          <p>
            Cette mini app pose les premières questions utiles, estime la complexité, détecte les zones à clarifier
            et génère un résumé prêt à envoyer. Elle montre la méthode autant que le code.
          </p>
        </div>
        <div class="app-card">
          <span class="status">Disponible</span>
          <h3>Assistant de cadrage</h3>
          <p>Besoin, complexité, contexte, risques, questions à clarifier et synthèse email.</p>
          <div class="product-preview" aria-label="Aperçu du résultat généré">
            <div>
              <span>Score</span>
              <strong>15/37</strong>
            </div>
            <div>
              <span>Lecture</span>
              <strong>Complexité moyenne</strong>
            </div>
            <ul>
              <li>Délai court à clarifier</li>
              <li>Version minimale à isoler</li>
              <li>Données existantes à valider</li>
            </ul>
          </div>
          <div class="button-row">
            <a class="button primary" href={briefHref}>Lancer l'assistant</a>
            <a class="button secondary" href={briefSourceUrl} rel="noreferrer" target="_blank">Voir le code</a>
          </div>
        </div>
      </section>

      <section class="section-pad strength-section">
        <div class="section-heading narrow">
          <p class="eyebrow">Ce que j'apporte</p>
          <h2>Une approche de lead dev appliquée à des projets courts, utiles et maintenables.</h2>
        </div>
        <div class="profile-strip">
          <span><strong>9 ans</strong> web métier</span>
          <span><strong>PHP</strong> backend</span>
          <span><strong>Lead</strong> cadrage</span>
          <span><strong>IA</strong> assistée</span>
        </div>
        <div class="strength-list">
          {strengths.map((item) => (
            <article>
              <span aria-hidden="true">OK</span>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="cadre" class="section-pad fit-section">
        <div class="fit-card good">
          <p class="eyebrow">Bon cadre</p>
          <h2>Le cadre dans lequel je peux vraiment apporter de la valeur.</h2>
          <ul>
            {goodFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="fit-card careful">
          <p class="eyebrow">Formats peu adaptés</p>
          <h2>Ce qui met le projet à risque.</h2>
          <ul>
            {badFit.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </section>

      <section class="section-pad frame-section">
        <div class="section-heading">
          <p class="eyebrow">Cadre d'intervention</p>
          <h2>Une disponibilité assumée, donc un cadre de travail clair.</h2>
          <p>
            Je prends peu de projets en parallèle. Le bon format est un projet utile, limité, avec des décisions claires
            et un rythme compatible avec une activité complémentaire.
          </p>
        </div>
        <div class="card-grid four">
          {operatingFrame.map((item) => (
            <article class="card compact-card">
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-pad process-section">
        <div class="section-heading">
          <p class="eyebrow">Méthode</p>
          <h2>Un déroulé court pour passer d'une demande à une version livrable.</h2>
          <p>
            La méthode complète est volontairement simple : comprendre le besoin, découper une V1, livrer quelque chose
            d'utilisable, puis décider si la suite mérite vraiment d'être construite.
          </p>
        </div>
        <div class="timeline-grid">
          {process.map(([number, title, text]) => (
            <article class="step-card">
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{text}</p>
            </article>
          ))}
        </div>
        <div class="method-link">
          <a class="button secondary" href={methodHref}>Voir la méthode détaillée</a>
        </div>
      </section>

      <section class="section-pad deliverables-section">
        <div class="section-heading">
          <p class="eyebrow">Livrables concrets</p>
          <h2>Des sorties utiles avant même de coder.</h2>
          <p>
            Un bon petit projet commence souvent par une meilleure formulation du besoin. Ces livrables évitent les devis
            vagues et les développements qui changent de forme en route.
          </p>
        </div>
        <div class="card-grid four">
          {deliverableExamples.map((item) => (
            <article class="card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="exemples" class="section-pad examples-section">
        <div class="section-heading">
          <p class="eyebrow">Exemples anonymisés</p>
          <h2>Des problématiques réalistes, sans donnée client ni détail confidentiel.</h2>
        </div>
        <article class="case-study featured-case">
          <div>
            <p class="eyebrow">Étude de cas anonymisée</p>
            <h3>{caseStudy.title}</h3>
            <div class="case-signal">
              <span>Risque évité</span>
              <strong>Mini ERP non cadré</strong>
            </div>
          </div>
          <div class="case-grid">
            <div>
              <strong>Contexte</strong>
              <p>{caseStudy.context}</p>
            </div>
            <div>
              <strong>Contrainte</strong>
              <p>{caseStudy.constraint}</p>
            </div>
            <div>
              <strong>Décision</strong>
              <p>{caseStudy.decision}</p>
            </div>
            <div>
              <strong>Résultat visé</strong>
              <p>{caseStudy.result}</p>
            </div>
          </div>
        </article>
        <div class="card-grid two">
          {examples.map((item) => (
            <article class="example-card">
              <h3>{item.title}</h3>
              <strong>Problème</strong>
              <p>{item.problem}</p>
              <strong>Réponse possible</strong>
              <p>{item.answer}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="contact" class="contact-section">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Commencez par un brief court.</h2>
          <p>
            Le plus simple est d'utiliser l'assistant de cadrage ou de m'envoyer votre contexte, votre objectif,
            votre délai et les contraintes déjà connues.
          </p>
        </div>
        <div class="contact-actions">
          <a class="button primary" href={briefHref}>Préparer un brief</a>
          <a class="button ghost" href={scoringSourceUrl} rel="noreferrer" target="_blank">Voir la logique de scoring</a>
          <a class="button ghost" href={mailHref}>Envoyer un email</a>
          <div class="social-links" aria-label="Liens secondaires">
            <a href={linkedinUrl} rel="noreferrer" target="_blank">LinkedIn</a>
            <a href={githubUrl} rel="noreferrer" target="_blank">GitHub</a>
          </div>
          <p>{contactEmail}</p>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f7f6f2;
    --bg-soft: #eef1ee;
    --surface: #ffffff;
    --ink: #202124;
    --muted: #62645f;
    --line: #d6ddd6;
    --accent: #326c60;
    --accent-dark: #1f493f;
    --cool: #415b66;
    --warm: #9a6548;
    --soft-green: #edf5f1;
    --soft-warm: #f6eee8;
    --shadow: 0 20px 54px rgba(32, 33, 36, 0.1);
    --shadow-strong: 0 28px 80px rgba(31, 73, 63, 0.18);
    --radius: 8px;
    --page: 1160px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  p,
  li {
    color: var(--muted);
  }

  .section-pad {
    padding: clamp(56px, 8vw, 104px) max(clamp(20px, 5vw, 72px), calc((100vw - var(--page)) / 2));
  }

  .hero {
    display: grid;
    min-height: calc(92vh - 73px);
    grid-template-columns: minmax(0, 0.98fr) minmax(360px, 0.72fr);
    gap: clamp(32px, 6vw, 78px);
    align-items: center;
  }

  .eyebrow,
  .panel-label {
    margin: 0 0 14px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
  }

  h1 {
    max-width: 920px;
    font-size: clamp(2.45rem, 5vw, 5rem);
    line-height: 1;
  }

  h2 {
    font-size: clamp(1.9rem, 3.2vw, 3.1rem);
    line-height: 1.06;
  }

  h3 {
    font-size: 1.16rem;
    line-height: 1.25;
  }

  .lead {
    max-width: 780px;
    margin: 26px 0 0;
    font-size: clamp(1.08rem, 1.7vw, 1.28rem);
    line-height: 1.62;
  }

  .small-note,
  .section-heading p,
  .card p,
  .app-copy p,
  .app-card p,
  .step-card p,
  .example-card p,
  .contact-section p {
    line-height: 1.62;
  }

  .small-note {
    max-width: 760px;
    margin: 18px 0 0;
  }

  .hero-actions,
  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 34px;
  }

  .button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 13px 18px;
    font-weight: 900;
    transition:
      background 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 24px rgba(32, 33, 36, 0.08);
  }

  .button:focus-visible,
  a:focus-visible {
    outline: 3px solid rgba(50, 108, 96, 0.28);
    outline-offset: 3px;
  }

  .button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .button.primary:hover {
    background: var(--accent-dark);
  }

  .button.secondary,
  .button.ghost {
    background: transparent;
  }

  .product-board,
  .card,
  .app-card,
  .strength-list article,
  .fit-card,
  .step-card,
  .example-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .product-board {
    position: relative;
    overflow: hidden;
    padding: clamp(22px, 4vw, 32px);
    box-shadow: var(--shadow-strong);
  }

  .product-board::before {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg, rgba(50, 108, 96, 0.16), transparent 38%),
      radial-gradient(circle at 92% 8%, rgba(65, 91, 102, 0.16), transparent 28%);
    content: "";
    pointer-events: none;
  }

  .product-board > * {
    position: relative;
  }

  .board-topline {
    display: inline-flex;
    gap: 10px;
    align-items: center;
    border: 1px solid rgba(50, 108, 96, 0.22);
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--accent-dark);
    background: rgba(237, 245, 241, 0.82);
    font-weight: 900;
  }

  .status-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 0 6px rgba(50, 108, 96, 0.12);
  }

  .board-score {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 20px;
    margin-top: 28px;
  }

  .board-score p {
    margin: 0 0 6px;
    color: var(--muted);
    font-weight: 850;
  }

  .board-score strong {
