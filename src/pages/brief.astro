---
const contactEmail = "vialgouteyron@gmail.com";
const asset = (path: string) =>
  `${import.meta.env.BASE_URL.replace(/\/?$/, "/")}${path.replace(/^\//, "")}`;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="icon" href={asset("favicon.ico")} />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Assistant de cadrage pour préparer un brief de site, outil web ou automatisation légère."
    />
    <title>Assistant de cadrage - Quentin Vial-Gouteyron</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={asset("")}>
        <span>Quentin Vial-Gouteyron</span>
        <small>Assistant de cadrage</small>
      </a>
      <nav>
        <a href={asset("")}>Portfolio</a>
        <a class="nav-cta" href="#resultat">Résultat</a>
      </nav>
    </header>

    <main>
      <section class="hero section-pad">
        <div>
          <p class="eyebrow">Brief Builder</p>
          <h1>Préparer un projet web sans partir dans le flou.</h1>
          <p class="lead">
            Répondez à quelques questions. L'assistant estime la complexité, signale les risques,
            liste les points à clarifier et génère un résumé prêt à envoyer.
          </p>
        </div>
        <aside class="summary-card">
          <strong>V1 volontairement simple</strong>
          <p>
            Pas de compte, pas de base de données, pas d'envoi automatique. Vos réponses restent dans votre navigateur
            et servent uniquement à préparer un brief clair.
          </p>
        </aside>
      </section>

      <form id="brief-form" class="brief-form section-pad">
        <div class="progress-panel" aria-live="polite">
          <div>
            <strong id="progress-label">Progression : 0/4</strong>
            <p id="progress-text">Complétez les champs utiles pour obtenir un brief exploitable.</p>
          </div>
          <button class="button secondary compact" type="button" id="reset-brief">Réinitialiser</button>
        </div>

        <section class="step">
          <div class="step-heading">
            <span>01</span>
            <div>
              <p class="eyebrow">Besoin</p>
              <h2>Quel type de projet préparez-vous ?</h2>
            </div>
          </div>
          <div class="option-grid">
            <label><input type="radio" name="projectType" value="Site clair" data-score="1" checked /> Site clair</label>
            <label><input type="radio" name="projectType" value="Outil métier léger" data-score="3" /> Outil métier léger</label>
            <label><input type="radio" name="projectType" value="Automatisation" data-score="3" /> Automatisation</label>
            <label><input type="radio" name="projectType" value="Refonte" data-score="2" /> Refonte</label>
            <label><input type="radio" name="projectType" value="Formulaire avancé" data-score="2" /> Formulaire avancé</label>
          </div>
          <label class="field">
            Objectif principal
            <textarea name="goal" rows="4" placeholder="Ex : centraliser les demandes, présenter une activité, éviter une double saisie..."></textarea>
          </label>
        </section>

        <section class="step">
          <div class="step-heading">
            <span>02</span>
            <div>
              <p class="eyebrow">Complexité</p>
              <h2>Quelles briques sont nécessaires ?</h2>
            </div>
          </div>
          <div class="option-grid">
            <label><input type="checkbox" name="features" value="Espace admin" data-score="2" /> Espace admin</label>
            <label><input type="checkbox" name="features" value="Droits utilisateurs" data-score="3" /> Droits utilisateurs</label>
            <label><input type="checkbox" name="features" value="Import / export" data-score="2" /> Import / export</label>
            <label><input type="checkbox" name="features" value="Notifications email" data-score="1" /> Notifications email</label>
            <label><input type="checkbox" name="features" value="Connexion à un outil existant" data-score="3" /> Connexion outil existant</label>
            <label><input type="checkbox" name="features" value="Historique ou journal" data-score="2" /> Historique ou journal</label>
            <label><input type="checkbox" name="features" value="Paiement" data-score="4" /> Paiement</label>
            <label><input type="checkbox" name="features" value="Documents générés" data-score="2" /> Documents générés</label>
          </div>
        </section>

        <section class="step">
          <div class="step-heading">
            <span>03</span>
            <div>
              <p class="eyebrow">Contexte</p>
              <h2>Le projet est-il prêt à être cadré ?</h2>
            </div>
          </div>
          <div class="field-grid">
            <label class="field">
              Délai souhaité
              <select name="deadline">
                <option value="Flexible" data-score="0">Flexible</option>
                <option value="1 à 2 mois" data-score="1">1 à 2 mois</option>
                <option value="Moins d'un mois" data-score="3">Moins d'un mois</option>
                <option value="Urgent" data-score="5">Urgent</option>
              </select>
            </label>
            <label class="field">
              Budget approximatif
              <select name="budget">
                <option value="Non défini" data-score="2">Non défini</option>
                <option value="Moins de 500 EUR" data-score="3">Moins de 500 EUR</option>
                <option value="500 à 1500 EUR" data-score="1">500 à 1500 EUR</option>
                <option value="1500 à 3000 EUR" data-score="0">1500 à 3000 EUR</option>
                <option value="Plus de 3000 EUR" data-score="0">Plus de 3000 EUR</option>
              </select>
            </label>
            <label class="field">
              Clarté du besoin
              <select name="clarity">
                <option value="Assez clair" data-score="0">Assez clair</option>
                <option value="Quelques zones floues" data-score="2">Quelques zones floues</option>
                <option value="Très flou" data-score="4">Très flou</option>
              </select>
            </label>
            <label class="field">
              Contenus ou données
              <select name="contentReady">
                <option value="Déjà prêts" data-score="0">Déjà prêts</option>
                <option value="Partiellement prêts" data-score="1">Partiellement prêts</option>
                <option value="Pas prêts" data-score="3">Pas prêts</option>
              </select>
            </label>
          </div>
        </section>

        <section class="step">
          <div class="step-heading">
            <span>04</span>
            <div>
              <p class="eyebrow">Précisions</p>
              <h2>Ajoutez le contexte utile.</h2>
            </div>
          </div>
          <div class="field-grid">
            <label class="field">
              Utilisateurs concernés
              <input name="users" placeholder="Ex : clients, équipe interne, bénévoles..." />
            </label>
            <label class="field">
              Outils ou données existants
              <input name="existingTools" placeholder="Ex : Excel, ERP, emails, site actuel..." />
            </label>
          </div>
          <label class="field">
            Contraintes importantes
            <textarea name="constraints" rows="4" placeholder="Ex : disponibilité, processus existant, reprise de données, validation interne..."></textarea>
          </label>
        </section>

        <section id="resultat" class="result-section">
          <div class="result-panel">
            <p class="eyebrow">Résultat</p>
            <h2 id="complexity-title">Complexité simple</h2>
            <p id="complexity-text">Remplissez le formulaire pour obtenir une synthèse.</p>
            <p class="score-detail" id="score-detail">Score indicatif : 0/0</p>
            <div class="score-bar" aria-hidden="true"><span id="score-fill"></span></div>
            <div class="result-grid">
              <article>
                <h3>Risques détectés</h3>
                <ul id="risk-list"></ul>
              </article>
              <article>
                <h3>Questions à clarifier</h3>
                <ul id="question-list"></ul>
              </article>
            </div>
          </div>
          <div class="output-panel">
            <label class="field">
              Résumé prêt à envoyer
              <textarea id="summary-output" rows="16" readonly></textarea>
            </label>
            <p class="copy-feedback" id="copy-feedback" role="status" aria-live="polite"></p>
            <div class="result-actions">
              <button class="button secondary" type="button" id="copy-summary">Copier</button>
              <a class="button primary" id="email-link" href={`mailto:${contactEmail}`}>Envoyer par email</a>
            </div>
          </div>
        </section>
      </form>
    </main>

    <script>
      import { evaluateBrief } from "../lib/briefScoring";

      const form = document.querySelector("#brief-form");
      const title = document.querySelector("#complexity-title");
      const text = document.querySelector("#complexity-text");
      const scoreDetail = document.querySelector("#score-detail");
      const scoreFill = document.querySelector("#score-fill");
      const riskList = document.querySelector("#risk-list");
      const questionList = document.querySelector("#question-list");
      const output = document.querySelector("#summary-output");
      const emailLink = document.querySelector("#email-link");
      const copyButton = document.querySelector("#copy-summary");
      const copyFeedback = document.querySelector("#copy-feedback");
      const progressLabel = document.querySelector("#progress-label");
      const progressText = document.querySelector("#progress-text");
      const resetButton = document.querySelector("#reset-brief");
      const storageKey = "qvg-brief-builder";
      const contactEmail = "vialgouteyron@gmail.com";

      const readCheckedValues = (name) =>
        Array.from(form.querySelectorAll(`[name="${name}"]:checked`)).map((field) => field.value);

      const getFormData = () => {
        const data = new FormData(form);
        return {
          projectType: data.get("projectType") || "",
          goal: data.get("goal") || "",
          features: readCheckedValues("features"),
          deadline: data.get("deadline") || "",
          budget: data.get("budget") || "",
          clarity: data.get("clarity") || "",
          contentReady: data.get("contentReady") || "",
          users: data.get("users") || "",
          existingTools: data.get("existingTools") || "",
          constraints: data.get("constraints") || "",
        };
      };

      const renderList = (node, items) => {
        node.innerHTML = "";
        items.forEach((item) => {
          const li = document.createElement("li");
          li.textContent = item;
          node.appendChild(li);
        });
      };

      const updateProgress = (data) => {
        const completed = [
          Boolean(data.projectType && data.goal.trim()),
          data.features.length > 0,
          data.deadline && data.budget && data.clarity && data.contentReady,
          Boolean(data.users.trim() || data.existingTools.trim() || data.constraints.trim()),
        ].filter(Boolean).length;

        progressLabel.textContent = `Progression : ${completed}/4`;
        progressText.textContent =
          completed >= 3
            ? "Le brief devient exploitable. Le résumé peut déjà servir de base de discussion."
            : "Complétez au moins l'objectif, quelques briques et le contexte pour obtenir une synthèse utile.";
      };

      const saveData = (data) => {
        try {
          localStorage.setItem(storageKey, JSON.stringify(data));
        } catch {
          progressText.textContent = "La sauvegarde locale est indisponible, mais le résumé reste utilisable.";
        }
      };

      const update = () => {
        const data = getFormData();
        const result = evaluateBrief(data);

        title.textContent = result.level.title;
        text.textContent = `${result.level.text} ${result.level.recommendation}`;
        scoreDetail.textContent = `Score indicatif : ${result.score}/${result.maxScore}`;
        scoreFill.style.width = `${Math.min(100, Math.round((result.score / result.maxScore) * 100))}%`;
        renderList(riskList, result.risks);
        renderList(questionList, result.questions);
        output.value = result.summary;
        emailLink.href = `mailto:${contactEmail}?subject=${encodeURIComponent("Brief projet web")}&body=${encodeURIComponent(result.summary)}`;
        updateProgress(data);
        saveData(data);
      };

      const restore = () => {
        const raw = localStorage.getItem(storageKey);
        if (!raw) return;
        try {
          const data = JSON.parse(raw);
          Object.entries(data).forEach(([key, value]) => {
            if (Array.isArray(value)) {
              value.forEach((item) => {
                const field = form.querySelector(`[name="${key}"][value="${CSS.escape(item)}"]`);
                if (field) field.checked = true;
              });
              return;
            }
            const field = form.querySelector(`[name="${key}"]`);
            if (!field) return;
            if (field.type === "radio") {
              const radio = form.querySelector(`[name="${key}"][value="${CSS.escape(value)}"]`);
              if (radio) radio.checked = true;
            } else {
              field.value = value;
            }
          });
        } catch {
          localStorage.removeItem(storageKey);
        }
      };

      copyButton.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(output.value);
          copyFeedback.textContent = "Résumé copié.";
          copyButton.textContent = "Copié";
          window.setTimeout(() => {
            copyFeedback.textContent = "";
            copyButton.textContent = "Copier";
          }, 1400);
        } catch {
          output.focus();
          output.select();
          copyFeedback.textContent = "Copie automatique indisponible. Le résumé est sélectionné.";
        }
      });

      resetButton.addEventListener("click", () => {
        localStorage.removeItem(storageKey);
        form.reset();
        update();
      });

      form.addEventListener("submit", (event) => {
        event.preventDefault();
        update();
      });
      form.addEventListener("input", update);
      form.addEventListener("change", update);
      restore();
      update();
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #f6f3ed;
    --bg-soft: #ece6dc;
    --surface: #ffffff;
    --ink: #202124;
    --muted: #66615b;
    --line: #d8d0c4;
    --accent: #3f6f62;
    --accent-dark: #28483f;
    --warm: #a06245;
    --soft-green: #edf5f1;
    --soft-warm: #f7eee8;
    --shadow: 0 20px 54px rgba(32, 33, 36, 0.1);
    --radius: 8px;
    --page: 1160px;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    color: var(--ink);
    background: var(--bg);
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px clamp(20px, 5vw, 72px);
    border-bottom: 1px solid rgba(216, 208, 196, 0.78);
    background: rgba(246, 243, 237, 0.94);
    backdrop-filter: blur(14px);
  }

  .brand {
    display: grid;
    gap: 2px;
    font-weight: 900;
  }

  .brand small,
  p,
  li,
  input,
  textarea,
  select {
    color: var(--muted);
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: clamp(12px, 2.3vw, 28px);
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  .nav-cta {
    border: 1px solid var(--accent);
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--accent-dark);
    background: var(--soft-green);
  }

  .section-pad {
    padding: clamp(48px, 7vw, 92px) max(clamp(20px, 5vw, 72px), calc((100vw - var(--page)) / 2));
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: var(--accent-dark);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p,
  label,
  textarea,
  input,
  select {
    overflow-wrap: anywhere;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    letter-spacing: 0;
  }

  h1 {
    max-width: 920px;
    font-size: clamp(2.35rem, 5vw, 4.7rem);
    line-height: 1;
  }

  h2 {
    font-size: clamp(1.55rem, 2.5vw, 2.35rem);
    line-height: 1.08;
  }

  h3 {
    font-size: 1.08rem;
    line-height: 1.28;
  }

  .lead,
  .summary-card p,
  .result-panel p {
    line-height: 1.62;
  }

  .lead {
    max-width: 780px;
    margin: 24px 0 0;
    font-size: clamp(1.06rem, 1.6vw, 1.22rem);
  }

  .summary-card,
  .step,
  .result-panel,
  .output-panel {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
  }

  .summary-card {
    padding: 24px;
    box-shadow: var(--shadow);
  }

  .brief-form {
    display: grid;
    gap: 18px;
    padding-top: 0;
  }

  .progress-panel {
    position: sticky;
    top: 76px;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 16px 18px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 10px 30px rgba(32, 33, 36, 0.07);
    backdrop-filter: blur(12px);
  }

  .progress-panel p {
    margin: 4px 0 0;
    line-height: 1.45;
  }

  .step {
    padding: clamp(22px, 4vw, 34px);
  }

  .step-heading {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    margin-bottom: 24px;
  }

  .step-heading > span {
    color: rgba(160, 98, 69, 0.42);
    font-size: 2.5rem;
    font-weight: 950;
    line-height: 1;
  }

  .option-grid,
  .field-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .option-grid label {
    display: flex;
    min-height: 52px;
    align-items: center;
    gap: 10px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 12px 14px;
    background: var(--bg);
    color: var(--ink);
    font-weight: 800;
  }

  input[type="radio"],
  input[type="checkbox"] {
    accent-color: var(--accent);
  }

  .field {
    display: grid;
    gap: 8px;
    margin-top: 18px;
    color: var(--ink);
    font-weight: 850;
  }

  input,
  textarea,
  select {
    width: 100%;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 12px 14px;
    background: #fff;
    font: inherit;
  }

  textarea {
    resize: vertical;
  }

  .result-section {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    gap: 18px;
    align-items: start;
  }

  .result-panel,
  .output-panel {
    padding: clamp(22px, 4vw, 34px);
  }

  .score-bar {
    height: 12px;
    margin: 22px 0;
    overflow: hidden;
    border-radius: 999px;
    background: var(--bg-soft);
  }

  .score-bar span {
    display: block;
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: var(--accent);
    transition: width 160ms ease;
  }

  .score-detail {
    margin: 12px 0 0;
    color: var(--accent-dark);
    font-weight: 850;
  }

  .result-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  ul {
    display: grid;
    gap: 10px;
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
  }

  li {
    position: relative;
    padding-left: 24px;
    line-height: 1.48;
  }

  li::before {
    position: absolute;
    left: 0;
    color: var(--accent);
    content: "+";
    font-weight: 900;
  }

  .result-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 14px;
  }

  .copy-feedback {
    min-height: 1.4em;
    margin: 10px 0 0;
    color: var(--accent-dark);
    font-weight: 800;
  }

  .button {
    display: inline-flex;
    min-height: 50px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    padding: 13px 18px;
    background: transparent;
    color: var(--ink);
    font: inherit;
    font-weight: 900;
    cursor: pointer;
  }

  .button.primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .button.secondary {
    background: #fff;
  }

  .button.compact {
    min-height: 42px;
    flex: 0 0 auto;
    padding: 10px 14px;
  }

  @media (max-width: 940px) {
    .hero,
    .result-section,
    .result-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 700px) {
    .site-header {
      position: static;
      align-items: flex-start;
      flex-direction: column;
    }

    .option-grid,
    .field-grid,
    .result-actions,
    .progress-panel {
      grid-template-columns: 1fr;
    }

    .progress-panel {
      position: static;
      align-items: stretch;
      flex-direction: column;
    }

    h1 {
      font-size: clamp(2.2rem, 12vw, 3.3rem);
    }

    .button {
      width: 100%;
    }
  }
</style>
